---
import SectionPage from '../../../layouts/SectionPage.astro';
import { getCollection } from 'astro:content';

const swiftProjects = await getCollection('swiftProjects');
const sorted = swiftProjects.sort((a, b) => {
	const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return db - da;
});
---

<SectionPage title="Swift Projects" description="iOS and macOS apps built with SwiftUI.">
	<Fragment slot="eyebrow">~/swift/projects</Fragment>
	<Fragment slot="heading">Swift Projects.</Fragment>
	<Fragment slot="description">Native apps for Apple platforms. Each one built to solve a real problem or learn something specific.</Fragment>

	<section class="section">
		<div class="container">
			{sorted.length === 0 ? (
				<div class="empty-state">
					<p class="empty-msg">No Swift projects yet. Add them via <a href="/keystatic" class="ks-link">/keystatic</a> → Swift Projects.</p>
				</div>
			) : (
				<div class="project-grid">
					{sorted.map((project) => {
						const tags = project.data.tags ? project.data.tags.split(',').map((t: string) => t.trim()) : [];
						const platformLabel = { ios: 'iOS', macos: 'macOS', both: 'iOS & macOS' }[project.data.platform] || project.data.platform;
						return (
							<article class="project-card">
								<div class="card-top">
									<div>
										<span class="card-name">{project.data.title}</span>
										<span class="card-platform">{platformLabel}</span>
									</div>
									<span class="card-status">● {project.data.status.replace('-', ' ')}</span>
								</div>
								<p class="card-desc">{project.data.description}</p>
								{tags.length > 0 && (
									<div class="card-tags">
										{tags.map((tag: string) => <span class="card-tag">{tag}</span>)}
									</div>
								)}
								<div class="card-links">
									{project.data.repoUrl && <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="clink">GitHub ↗</a>}
									{project.data.appStoreUrl && <a href={project.data.appStoreUrl} target="_blank" rel="noopener noreferrer" class="clink">App Store ↗</a>}
								</div>
							</article>
						);
					})}
				</div>
			)}
		</div>
	</section>
</SectionPage>

<style>
	.container { max-width: 1060px; margin: 0 auto; padding: 0 2rem; }
	.section { padding: 2rem 0 6rem; }

	.empty-state { padding: 3rem 0; }
	.empty-msg { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; color: rgba(var(--fg-rgb),0.35); }
	.ks-link { color: var(--accent); text-decoration: none; }
	.ks-link:hover { text-decoration: underline; }

	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: 1.25rem;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		padding: 2rem;
		background: var(--bg-card);
		border: 1px solid rgba(var(--accent-rgb),0.1);
		border-top: 2px solid rgba(var(--accent-rgb),0.35);
		border-radius: 14px;
		transition: border-color 0.25s ease, box-shadow 0.25s ease;
	}
	.project-card:hover {
		border-color: rgba(var(--accent-rgb),0.25);
		border-top-color: var(--accent);
		box-shadow: 0 8px 32px rgba(var(--accent-rgb),0.1);
	}

	.card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; }
	.card-name { font-family: 'Syne', sans-serif; font-size: 1.35rem; font-weight: 800; color: var(--fg); letter-spacing: -0.02em; display: block; }
	.card-platform { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: rgba(var(--fg-rgb),0.3); letter-spacing: 0.06em; }
	.card-status { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #4ade80; white-space: nowrap; text-transform: capitalize; flex-shrink: 0; padding-top: 0.25rem; }
	.card-desc { font-family: 'Inter', sans-serif; font-size: 0.9rem; color: rgba(var(--fg-rgb),0.55); line-height: 1.65; margin: 0; }
	.card-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: auto; }
	.card-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; padding: 0.18rem 0.5rem; background: rgba(var(--accent-rgb),0.07); color: var(--accent); border: 1px solid rgba(var(--accent-rgb),0.18); border-radius: 5px; }
	.card-links { display: flex; gap: 0.6rem; }
	.clink { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: rgba(var(--fg-rgb),0.35); text-decoration: none; transition: color 0.2s ease; }
	.clink:hover { color: var(--accent); }

	@media (max-width: 640px) {
		.container { padding: 0 1.5rem; }
		.project-grid { grid-template-columns: 1fr; }
	}
</style>
