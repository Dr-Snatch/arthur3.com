---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';
import { projects } from '../data/projects';

const buildLog = [
	{ hash: '3f8a2d1', date: 'Mar 2026', message: 'Started building an AI-powered security scanner — prompt injection, OWASP checks, LLM reasoning.' },
	{ hash: '9c2b4e8', date: 'Feb 2026', message: 'Shipped a full-stack web app. React frontend, FastAPI backend, Postgres. Actually deployed it.' },
	{ hash: 'a1e7f93', date: 'Jan 2026', message: 'Deep dive into web application vulnerabilities. SQLi, XSS, CSRF. Broke a lot of test apps.' },
	{ hash: 'd5c3b21', date: 'Dec 2025', message: 'Built a RAG-based coding assistant. Context window management is harder than it looks.' },
	{ hash: '7b9a4f6', date: 'Nov 2025', message: 'Launched arthur3.com. Astro + Cloudflare Pages. Fast by default.' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Nav />

		<main>

			<!-- ── HERO ── -->
			<section class="hero">
				<div class="hero-inner">
					<p class="status-chip">
						<span class="status-dot" aria-hidden="true"></span>
						AI Undergrad · 20 · UK
					</p>

					<h1 class="hero-heading">
						Building software<br />at the edge of<br />AI and security.
					</h1>

					<div class="terminal-line" aria-label="Currently">
						<span class="prompt">~$</span>
						<span class="cycling" id="cycling-text">experimenting with LLM agents</span>
						<span class="cursor" aria-hidden="true"></span>
					</div>

					<div class="hero-actions">
						<a href="#projects" class="btn-primary">View Projects</a>
						<a href="/blog" class="btn-ghost">Read the blog</a>
					</div>
				</div>
			</section>

			<!-- ── MARQUEE ── -->
			<div class="marquee-wrap" aria-hidden="true">
				<div class="marquee-track">
					{[
						'Python', 'TypeScript', 'React', 'FastAPI', 'LLMs', 'Docker',
						'PostgreSQL', 'Linux', 'Bash', 'Machine Learning', 'Security',
						'Next.js', 'Git', 'Automation',
						'Python', 'TypeScript', 'React', 'FastAPI', 'LLMs', 'Docker',
						'PostgreSQL', 'Linux', 'Bash', 'Machine Learning', 'Security',
						'Next.js', 'Git', 'Automation',
					].map((t) => (
						<span class="marquee-item">{t}<span class="marquee-dot">·</span></span>
					))}
				</div>
			</div>

			<!-- ── PROJECTS ── -->
			<section id="projects" class="section">
				<div class="container">
					<div class="section-row">
						<h2 class="section-h2">Projects</h2>
						<a href="https://github.com/Dr-Snatch" target="_blank" rel="noopener noreferrer" class="section-link">
							github.com/Dr-Snatch ↗
						</a>
					</div>
					<div class="projects-grid">
						{projects.map((project, i) => (
							<div class="reveal" style={`transition-delay:${i*0.07}s`}>
								<ProjectCard {...project} />
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ── ABOUT ── -->
			<section class="section section-dark">
				<div class="container about-layout">
					<div class="about-text">
						<p>
							I'm Arthur — a 20-year-old studying Artificial Intelligence in the UK.
							I spend most of my time building things: apps, tools, experiments.
							The kind of software that does something useful, or at least teaches me something new.
						</p>
						<p>
							Right now I'm particularly interested in what happens when you combine
							AI with security — adversarial prompting, LLM-powered vulnerability scanning,
							that sort of thing. It's a weird, fast-moving space and I'm here for it.
						</p>
						<p class="about-interests">
							Also into: CTFs · automation scripts · systems programming · anything that runs on Linux.
						</p>
					</div>
					<div class="about-meta">
						<div class="meta-item">
							<span class="meta-key">status</span>
							<span class="meta-val">open to work</span>
						</div>
						<div class="meta-item">
							<span class="meta-key">based</span>
							<span class="meta-val">United Kingdom</span>
						</div>
						<div class="meta-item">
							<span class="meta-key">studying</span>
							<span class="meta-val">AI / CS</span>
						</div>
						<div class="meta-item">
							<span class="meta-key">shipping since</span>
							<span class="meta-val">age 15</span>
						</div>
					</div>
				</div>
			</section>

			<!-- ── BUILD LOG ── -->
			<section class="section" id="log">
				<div class="container">
					<h2 class="section-h2">Build Log</h2>
					<div class="gitlog">
						{buildLog.map((entry, i) => (
							<div class="commit reveal" style={`transition-delay:${i*0.07}s`}>
								<div class="commit-meta">
									<code class="commit-hash">{entry.hash}</code>
									<span class="commit-date">{entry.date}</span>
								</div>
								<p class="commit-msg">{entry.message}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ── CONTACT ── -->
			<section id="contact" class="section section-dark">
				<div class="container">
					<h2 class="contact-heading">Say hi.</h2>
					<p class="contact-sub">Open to interesting projects, collaborations, and conversations.</p>
					<div class="contact-links">
						{SOCIAL_LINKS.map((link) => {
							const isEmail = link.href.startsWith('mailto:');
							return (
								<a
									href={link.href}
									target={isEmail ? undefined : '_blank'}
									rel={isEmail ? undefined : 'noopener noreferrer'}
									class="contact-link"
								>
									{link.label} <span class="arrow" aria-hidden="true">↗</span>
								</a>
							);
						})}
					</div>
				</div>
			</section>

		</main>

		<Footer />
	</body>
</html>

<script>
	// Cycling terminal text
	const phrases = [
		'experimenting with LLM agents',
		'breaking things to understand them',
		'studying adversarial ML',
		'shipping software from the UK',
		'solving CTF challenges',
		'reading about application security',
	];
	let idx = 0;
	const el = document.getElementById('cycling-text');
	if (el) {
		setInterval(() => {
			el.style.opacity = '0';
			setTimeout(() => {
				idx = (idx + 1) % phrases.length;
				el.textContent = phrases[idx];
				el.style.opacity = '1';
			}, 250);
		}, 3200);
	}

	// Scroll reveal
	const obs = new IntersectionObserver(
		(entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
		{ threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
	);
	document.addEventListener('DOMContentLoaded', () => {
		document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
	});
</script>

<style>
	body { padding-top: 0; }

	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	.container {
		max-width: 1060px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* ── Reveal animation ── */
	.reveal {
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.55s ease, transform 0.55s ease;
	}
	.reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* ── Buttons ── */
	.btn-primary {
		display: inline-block;
		padding: 0.7rem 1.6rem;
		background: #6366F1;
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.9rem;
		transition: background 0.2s ease, transform 0.15s ease;
	}
	.btn-primary:hover { background: #4F46E5; color: #fff; transform: translateY(-1px); }

	.btn-ghost {
		display: inline-block;
		padding: 0.7rem 1.6rem;
		background: transparent;
		color: rgba(255,255,255,0.6);
		text-decoration: none;
		border-radius: 8px;
		font-weight: 500;
		font-size: 0.9rem;
		border: 1px solid rgba(255,255,255,0.1);
		transition: color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
	}
	.btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.25); transform: translateY(-1px); }

	/* ── HERO ── */
	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding: 9rem 2rem 6rem;
	}

	.hero-inner {
		max-width: 1060px;
		margin: 0 auto;
		width: 100%;
	}

	.status-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: rgba(255,255,255,0.6);
		margin: 0 0 2rem 0;
		letter-spacing: 0.04em;
	}

	.status-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #4ade80;
		box-shadow: 0 0 6px #4ade80;
		animation: pulse 2s ease-in-out infinite;
		flex-shrink: 0;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	.hero-heading {
		font-size: clamp(2.8rem, 7vw, 5.5rem);
		font-weight: 700;
		line-height: 1.08;
		letter-spacing: -0.04em;
		color: #fff;
		margin: 0 0 2.5rem 0;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 2.5rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9rem;
	}

	.prompt {
		color: #6366F1;
		user-select: none;
	}

	.cycling {
		color: rgba(255,255,255,0.8);
		transition: opacity 0.25s ease;
	}

	.cursor {
		display: inline-block;
		width: 9px;
		height: 1.1em;
		background: #6366F1;
		border-radius: 1px;
		animation: blink 1s step-end infinite;
		vertical-align: text-bottom;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.hero-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	/* ── MARQUEE ── */
	.marquee-wrap {
		border-top: 1px solid rgba(255,255,255,0.1);
		border-bottom: 1px solid rgba(255,255,255,0.1);
		overflow: hidden;
		padding: 0.75rem 0;
	}

	.marquee-track {
		display: flex;
		width: max-content;
		animation: marquee 35s linear infinite;
	}

	.marquee-item {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: rgba(255,255,255,0.45);
		padding: 0 0.25rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.marquee-dot {
		margin: 0 0.75rem;
		color: rgba(99,102,241,0.5);
	}

	@keyframes marquee {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	/* ── SECTION BASE ── */
	.section {
		padding: 6rem 0;
	}

	.section-dark {
		background: #16161C;
	}

	.section-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 2.5rem;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.section-h2 {
		font-size: 0.8rem;
		font-weight: 600;
		color: rgba(255,255,255,0.65);
		letter-spacing: 0.06em;
		margin: 0 0 2.5rem 0;
		text-transform: uppercase;
		font-family: 'JetBrains Mono', monospace;
	}

	.section-row .section-h2 {
		margin: 0;
	}

	.section-link {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: rgba(255,255,255,0.45);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.section-link:hover { color: rgba(255,255,255,0.85); }

	/* ── PROJECTS ── */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1rem;
	}

	/* ── ABOUT ── */
	.about-layout {
		display: grid;
		grid-template-columns: 1fr 260px;
		gap: 5rem;
		align-items: start;
	}

	.about-text p {
		font-size: 1.05rem;
		line-height: 1.75;
		color: rgba(255,255,255,0.8);
		margin-bottom: 1.25rem;
	}

	.about-text p:last-child { margin-bottom: 0; }

	.about-interests {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.82rem !important;
		color: rgba(255,255,255,0.5) !important;
		letter-spacing: 0.02em;
	}

	.about-meta {
		display: flex;
		flex-direction: column;
		gap: 0;
		padding-top: 0.25rem;
	}

	.meta-item {
		display: flex;
		justify-content: space-between;
		padding: 0.65rem 0;
		border-bottom: 1px solid rgba(255,255,255,0.1);
		gap: 1rem;
	}

	.meta-key {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		color: rgba(255,255,255,0.45);
		letter-spacing: 0.04em;
	}

	.meta-val {
		font-size: 0.85rem;
		color: rgba(255,255,255,0.85);
		text-align: right;
	}

	/* ── GIT LOG ── */
	.gitlog {
		display: flex;
		flex-direction: column;
	}

	.commit {
		display: grid;
		grid-template-columns: 220px 1fr;
		gap: 2rem;
		padding: 1.25rem 0;
		border-bottom: 1px solid rgba(255,255,255,0.09);
		align-items: start;
	}

	.commit-meta {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.commit-hash {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: #6366F1;
		letter-spacing: 0.04em;
	}

	.commit-date {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		color: rgba(255,255,255,0.4);
	}

	.commit-msg {
		font-size: 0.92rem;
		color: rgba(255,255,255,0.75);
		line-height: 1.6;
		margin: 0;
	}

	/* ── CONTACT ── */
	.contact-heading {
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 700;
		letter-spacing: -0.04em;
		color: #fff;
		margin: 0 0 0.75rem 0;
	}

	.contact-sub {
		font-size: 1rem;
		color: rgba(255,255,255,0.6);
		margin: 0 0 2rem 0;
	}

	.contact-links {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.contact-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.6rem 1.25rem;
		background: rgba(255,255,255,0.04);
		border: 1px solid rgba(255,255,255,0.12);
		border-radius: 8px;
		color: rgba(255,255,255,0.75);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}

	.contact-link:hover {
		color: #fff;
		border-color: rgba(99,102,241,0.5);
		background: rgba(99,102,241,0.06);
	}

	.arrow { color: rgba(255,255,255,0.25); font-size: 0.8rem; }
	.contact-link:hover .arrow { color: #6366F1; }

	/* ── Responsive ── */
	@media (max-width: 860px) {
		.about-layout {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
		.about-meta {
			max-width: 360px;
		}
	}

	@media (max-width: 640px) {
		.hero { padding: 8rem 1.5rem 5rem; }
		.container { padding: 0 1.5rem; }
		.section { padding: 4.5rem 0; }
		.commit {
			grid-template-columns: 1fr;
			gap: 0.4rem;
		}
		.contact-links { flex-direction: column; }
	}

	@media (prefers-reduced-motion: reduce) {
		.reveal { opacity: 1; transform: none; transition: none; }
		.cursor { animation: none; opacity: 1; }
		.status-dot { animation: none; }
		.marquee-track { animation: none; }
	}
</style>
