---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import TerminalBar from '../components/TerminalBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const allProjects = await getCollection('projects');
const beatMapProject = allProjects.find((project) => project.id === 'beatmap');
const supportingProjects = allProjects
	.filter((project) => project.id !== 'beatmap')
	.sort((a, b) => {
		const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
		const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
		return db - da;
	})
	.slice(0, 2);

const allNotes = (await getCollection('lab')).sort((a, b) => {
	const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return db - da;
});

const highlightedNotes = ['shazam-benchmarks', 'prompt-sandwich']
	.map((id) => allNotes.find((note) => note.id === id))
	.filter(Boolean);

const homeNotes = highlightedNotes.length === 2 ? highlightedNotes : allNotes.slice(0, 2);

const heroSignals = [
	'Newcastle, UK / remote',
	'Available for selected product work',
	'Terminal-led portfolio experience',
];

const heroModes = ['Structured LLM pipelines', 'Secure mobile auth', 'Product-grade tooling'];

const studioLedger = [
	{
		label: 'Best fit',
		copy: 'Recruiters, founders, and teams building AI products with real constraints.',
	},
	{
		label: 'Bias',
		copy: 'Reliable systems, direct communication, and products that still feel good after the first release.',
	},
	{
		label: 'Why this site',
		copy: 'Editorial presentation up top, terminal navigation underneath. Product thinking and systems thinking in one place.',
	},
];

const buildAreas = [
	{
		title: 'AI systems',
		copy: 'Structured output pipelines, streaming UX, and model-driven software that stays reliable under real input.',
	},
	{
		title: 'Secure native apps',
		copy: 'Mobile products with hardened auth, durable local storage, and careful handling of lifecycle edge cases.',
	},
	{
		title: 'Product-minded tooling',
		copy: 'Developer tools and integrations that make brittle workflows repeatable, inspectable, and faster to ship.',
	},
];

const principles = [
	'Reliability over novelty',
	'Security has to survive real use',
	'Structured outputs beat vague automation',
	'Small systems should still feel like products',
];

const githubLink = SOCIAL_LINKS.find((link) => link.label === 'GitHub');

function getTags(tagString, limit = 3) {
	return tagString ? tagString.split(',').map((tag) => tag.trim()).slice(0, limit) : [];
}

const beatMapSummary = beatMapProject
	? [
			{ label: 'Problem', value: beatMapProject.data.problem },
			{ label: 'System', value: beatMapProject.data.system },
			{ label: 'Result', value: beatMapProject.data.result },
		].filter((item) => item.value)
	: [];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Nav />
		<TerminalBar />

		<main>
			<section class="hero-section">
				<div class="container hero-layout">
					<div class="hero-copy">
						<p class="eyebrow">Arthur Wheildon / AI Systems Developer</p>
						<h1 class="hero-title">Software for messy reality.</h1>
						<p class="hero-description">
							I build structured LLM workflows, secure native apps, and product-grade tooling for teams that care what happens after the demo.
						</p>
						<p class="hero-manifesto">
							Clear systems, sharp interfaces, and engineering choices that can survive contact with actual users.
						</p>
						<div class="hero-actions">
							<a href="/contact" class="btn btn-primary">Start a Project</a>
							<a href="#beatmap" class="btn btn-secondary">See BeatMap</a>
						</div>
						<div class="signal-row">
							{heroSignals.map((signal) => (
								<span class="signal-pill">{signal}</span>
							))}
						</div>
					</div>

					<div class="hero-rail">
						<article class="hero-panel hero-panel-strong">
							<p class="panel-label">Operating mode</p>
							<h2 class="panel-title">Product-minded engineering with the sharp edges left visible.</h2>
							<p class="panel-copy">
								The goal is not just fast prototypes. It is software with strong defaults, careful tradeoffs, and enough rigor to keep working under actual pressure.
							</p>
							<div class="mini-matrix">
								{heroModes.map((mode) => (
									<span class="matrix-cell">{mode}</span>
								))}
							</div>
						</article>

						<article class="hero-panel">
							<p class="panel-label">Quick read</p>
							<div class="hero-ledger">
								{studioLedger.map((item) => (
									<article class="ledger-item">
										<p class="ledger-label">{item.label}</p>
										<p class="ledger-copy">{item.copy}</p>
									</article>
								))}
							</div>
							<div class="command-row">
								<span class="command-chip">help</span>
								<span class="command-chip">projects</span>
								<span class="command-chip">contact</span>
							</div>
						</article>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-head">
						<p class="eyebrow">Systems I Build</p>
						<h2 class="section-title">Clear product positioning instead of a tool list.</h2>
					</div>
					<div class="area-grid">
						{buildAreas.map((area) => (
							<article class="area-card">
								<h3 class="area-title">{area.title}</h3>
								<p class="area-copy">{area.copy}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			{beatMapProject && (
				<section class="section flagship-section" id="beatmap">
					<div class="container flagship-grid">
						<div class="flagship-copy">
							<p class="eyebrow">Flagship Product</p>
							<span class="product-badge">BeatMap · iOS</span>
							<h2 class="section-title">Music journaling with hardened Spotify auth and durable on-device data.</h2>
							<p class="flagship-description">
								{beatMapProject.data.headline ?? beatMapProject.data.description}
							</p>
							<div class="summary-grid">
								{beatMapSummary.map((item) => (
									<article class="summary-card">
										<p class="summary-label">{item.label}</p>
										<p class="summary-copy">{item.value}</p>
									</article>
								))}
							</div>
							<div class="hero-actions">
								<a href={`/projects/${beatMapProject.id}`} class="btn btn-primary">Read Case Study</a>
								{beatMapProject.data.repoUrl && (
									<a href={beatMapProject.data.repoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
										GitHub
									</a>
								)}
							</div>
						</div>

						<div class="shot-rail">
							<div class="shot-stack">
								<img
									src="/beatmap-shot-map.svg"
									alt="BeatMap placeholder showing a music map and secure auth card"
									class="product-shot product-shot-primary"
									loading="eager"
								/>
								<img
									src="/beatmap-shot-journal.svg"
									alt="BeatMap placeholder showing a journal entry and insights cards"
									class="product-shot product-shot-secondary"
								/>
							</div>
							<article class="proof-card">
								<p class="proof-label">What matters</p>
								<ul class="proof-list">
									<li>OAuth 2.0 PKCE built without third-party auth libraries</li>
									<li>Core Data migration and durable offline-friendly storage</li>
									<li>ShazamKit benchmarking that directly shaped the UX</li>
								</ul>
							</article>
						</div>
					</div>
				</section>
			)}

			<section class="section">
				<div class="container work-layout">
					<div class="section-head section-head-inline">
						<div>
							<p class="eyebrow">More Work</p>
							<h2 class="section-title">Supporting systems and technical notes.</h2>
						</div>
						<a href="/projects" class="text-link">Browse all projects ↗</a>
					</div>

					<div class="work-grid">
						{supportingProjects.map((project) => (
							<article class="project-card">
								<div class="card-top">
									<p class="card-kicker">{project.data.status.replace('-', ' ')}</p>
									<p class="card-title">{project.data.title}</p>
								</div>
								<p class="card-copy">{project.data.headline ?? project.data.description}</p>
								<div class="card-tag-row">
									{getTags(project.data.tags).map((tag) => (
										<span class="card-tag">{tag}</span>
									))}
								</div>
								<a href={`/projects/${project.id}`} class="text-link">Read case study ↗</a>
							</article>
						))}
					</div>

					<div class="notes-grid">
						{homeNotes.map((note) => (
							<article class="note-card">
								<p class="card-kicker">{note.data.status}</p>
								<p class="card-title">{note.data.title}</p>
								<p class="card-copy">{note.data.result ?? note.data.description}</p>
								<a href={`/lab/${note.id}`} class="text-link">Read note ↗</a>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-head">
						<p class="eyebrow">Engineering Principles</p>
						<h2 class="section-title">Simple standards that keep the work serious.</h2>
					</div>
					<div class="principles-grid">
						{principles.map((principle) => (
							<div class="principle-card">{principle}</div>
						))}
					</div>
				</div>
			</section>

			<section class="section cta-section">
				<div class="container">
					<div class="cta-panel">
						<div>
							<p class="eyebrow">Contact</p>
							<h2 class="section-title">Recruiters, founders, and teams building AI products.</h2>
							<p class="cta-copy">
								Best fit: AI systems, secure mobile experiences, and technical product work that needs careful engineering rather than shallow demos.
							</p>
						</div>
						<div class="hero-actions">
							<a href="/contact" class="btn btn-primary">Let's Work</a>
							{githubLink && (
								<a href={githubLink.href} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
									GitHub
								</a>
							)}
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section {
		padding: 0 0 5.75rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted-faint);
	}

	.eyebrow::before {
		content: '';
		width: 2.5rem;
		height: 1px;
		background: rgba(var(--accent-blue-rgb), 0.34);
	}

	.hero-section {
		padding: 1.45rem 0 4.75rem;
	}

	.hero-layout,
	.flagship-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.14fr) minmax(330px, 0.86fr);
		gap: 1.25rem;
		align-items: stretch;
	}

	.hero-copy {
		position: relative;
		padding: 2rem 2rem 2.15rem;
		border-radius: 42px;
		border: 1px solid var(--border);
		background: var(--surface-card-strong);
		box-shadow: var(--panel-shadow);
		overflow: hidden;
	}

	.hero-copy::after {
		content: '';
		position: absolute;
		top: -4rem;
		right: -2rem;
		width: 15rem;
		height: 15rem;
		border-radius: 40% 60% 55% 45% / 45% 38% 62% 55%;
		background: radial-gradient(circle, rgba(var(--accent-rgb), 0.24), transparent 62%);
		transform: rotate(18deg);
		opacity: 0.85;
	}

	.hero-copy > * {
		position: relative;
		z-index: 1;
	}

	.hero-title {
		max-width: 9ch;
		font-size: clamp(3.8rem, 8vw, 6.8rem);
		margin-bottom: 1.1rem;
		text-wrap: balance;
	}

	.hero-description,
	.flagship-description,
	.panel-copy,
	.area-copy,
	.card-copy,
	.summary-copy,
	.cta-copy {
		color: var(--muted-soft);
		line-height: 1.75;
	}

	.hero-description {
		max-width: 36rem;
		font-size: 1.14rem;
		margin-bottom: 1rem;
	}

	.hero-manifesto {
		max-width: 34rem;
		margin: 0 0 1.7rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		line-height: 1.85;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgba(var(--fg-rgb), 0.58);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.btn,
	.text-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, color 0.18s ease;
	}

	.btn {
		padding: 0.95rem 1.22rem;
		border-radius: 18px;
		border: 1px solid transparent;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.btn-primary {
		background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.96), rgba(245, 151, 111, 0.94));
		color: var(--paper);
		box-shadow: 0 16px 34px rgba(var(--accent-rgb), 0.18);
	}

	.btn-primary:hover {
		color: var(--paper);
		transform: translateY(-1px);
	}

	.btn-secondary {
		border-color: rgba(var(--accent-blue-rgb), 0.16);
		background: rgba(var(--paper-rgb), 0.65);
		color: var(--accent-blue-dark);
	}

	.btn-secondary:hover,
	.text-link:hover {
		transform: translateY(-1px);
		color: var(--accent-blue-dark);
		border-color: rgba(var(--accent-blue-rgb), 0.28);
	}

	.signal-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-top: 1.35rem;
	}

	.signal-pill,
	.command-chip,
	.card-tag,
	.product-badge {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.signal-pill {
		padding: 0.55rem 0.8rem;
		border-radius: 18px;
		background: rgba(var(--paper-rgb), 0.72);
		border: 1px solid rgba(var(--fg-rgb), 0.08);
		color: rgba(var(--fg-rgb), 0.82);
	}

	.hero-rail {
		display: grid;
		gap: 1rem;
	}

	.hero-panel,
	.area-card,
	.summary-card,
	.project-card,
	.note-card,
	.proof-card,
	.cta-panel {
		position: relative;
		overflow: hidden;
		border-radius: 28px;
		border: 1px solid var(--border);
		background: var(--surface-card);
		box-shadow: var(--box-shadow);
	}

	.hero-panel,
	.area-card,
	.project-card,
	.note-card,
	.proof-card {
		padding: 1.35rem;
	}

	.hero-panel-strong {
		background: var(--surface-card-contrast);
		color: var(--paper);
	}

	.panel-label,
	.summary-label,
	.proof-label,
	.card-kicker {
		margin: 0 0 0.65rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted-faint);
	}

	.hero-panel-strong .panel-label,
	.flagship-grid .summary-label,
	.flagship-grid .proof-label,
	.flagship-grid .eyebrow {
		color: rgba(var(--paper-rgb), 0.62);
	}

	.panel-title,
	.card-title,
	.area-title {
		margin: 0 0 0.75rem;
		font-family: 'Fraunces', serif;
		font-size: 1.6rem;
		letter-spacing: -0.04em;
	}

	.hero-panel-strong .panel-title,
	.flagship-grid .section-title {
		color: var(--paper);
	}

	.hero-panel-strong .panel-copy,
	.flagship-grid .flagship-description,
	.flagship-grid .summary-copy,
	.flagship-grid .proof-list {
		color: rgba(var(--paper-rgb), 0.8);
	}

	.mini-matrix,
	.hero-ledger {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	.mini-matrix {
		margin-top: 1rem;
	}

	.hero-ledger {
		display: grid;
		gap: 0.75rem;
	}

	.matrix-cell,
	.ledger-label,
	.ledger-copy {
		font-family: 'JetBrains Mono', monospace;
	}

	.matrix-cell {
		padding: 0.55rem 0.7rem;
		border-radius: 14px;
		border: 1px solid rgba(var(--paper-rgb), 0.16);
		background: rgba(var(--paper-rgb), 0.08);
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(var(--paper-rgb), 0.88);
	}

	.ledger-item {
		padding: 0.85rem 0.95rem;
		border-radius: 18px;
		border: 1px solid rgba(var(--fg-rgb), 0.08);
		background: rgba(var(--paper-rgb), 0.66);
	}

	.ledger-label {
		margin: 0 0 0.4rem;
		font-size: 0.66rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-blue-dark);
	}

	.ledger-copy {
		margin: 0;
		font-size: 0.8rem;
		line-height: 1.7;
		color: rgba(var(--fg-rgb), 0.72);
	}

	.command-row,
	.card-tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.command-row {
		margin-top: 1rem;
	}

	.command-chip {
		padding: 0.4rem 0.65rem;
		border-radius: 999px;
		border: 1px solid rgba(var(--accent-blue-rgb), 0.14);
		background: rgba(var(--accent-blue-rgb), 0.08);
		color: var(--accent-blue-dark);
	}

	.section-head {
		margin-bottom: 1.6rem;
	}

	.section-head-inline {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.section-title {
		max-width: 13ch;
		font-size: clamp(2.4rem, 4.5vw, 4rem);
	}

	.area-grid,
	.work-grid,
	.notes-grid,
	.principles-grid {
		display: grid;
		gap: 1rem;
	}

	.area-grid {
		grid-template-columns: repeat(12, minmax(0, 1fr));
	}

	.area-card:nth-child(1) {
		grid-column: span 5;
	}

	.area-card:nth-child(2) {
		grid-column: span 3;
		margin-top: 1.25rem;
	}

	.area-card:nth-child(3) {
		grid-column: span 4;
	}

	.flagship-section {
		padding-bottom: 6rem;
	}

	.flagship-grid {
		position: relative;
		padding: 2rem;
		border: 1px solid rgba(var(--paper-rgb), 0.1);
		border-radius: 40px;
		background: var(--surface-card-contrast);
		box-shadow: 0 30px 90px rgba(14, 22, 39, 0.24);
		overflow: hidden;
	}

	.flagship-grid::after {
		content: '';
		position: absolute;
		right: -4rem;
		bottom: -6rem;
		width: 20rem;
		height: 20rem;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(var(--accent-rgb), 0.18), transparent 70%);
	}

	.flagship-copy,
	.shot-rail {
		position: relative;
		z-index: 1;
	}

	.product-badge {
		display: inline-flex;
		padding: 0.5rem 0.75rem;
		border-radius: 999px;
		border: 1px solid rgba(var(--paper-rgb), 0.16);
		background: rgba(var(--paper-rgb), 0.08);
		color: rgba(var(--paper-rgb), 0.88);
		margin-bottom: 1rem;
	}

	.summary-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
		margin: 1.4rem 0 1.6rem;
	}

	.summary-card {
		padding: 1rem;
	}

	.flagship-grid .summary-card,
	.flagship-grid .proof-card {
		background: rgba(var(--paper-rgb), 0.08);
		border: 1px solid rgba(var(--paper-rgb), 0.12);
		box-shadow: none;
	}

	.shot-rail {
		display: grid;
		gap: 1rem;
	}

	.shot-stack {
		position: relative;
		min-height: 36rem;
	}

	.product-shot {
		border-radius: 28px;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.22);
		border: 1px solid rgba(var(--paper-rgb), 0.12);
	}

	.product-shot-primary {
		width: min(26rem, 100%);
		transform: rotate(-3deg);
	}

	.product-shot-secondary {
		position: absolute;
		right: 0;
		bottom: 0;
		width: min(18rem, 56%);
		transform: rotate(4deg);
	}

	.proof-list {
		margin: 0;
		padding-left: 1.1rem;
	}

	.proof-list li + li {
		margin-top: 0.65rem;
	}

	.work-layout {
		display: grid;
		gap: 1rem;
	}

	.work-grid {
		grid-template-columns: repeat(12, minmax(0, 1fr));
	}

	.notes-grid {
		grid-template-columns: repeat(12, minmax(0, 1fr));
	}

	.work-grid .project-card:nth-child(1) {
		grid-column: span 7;
	}

