---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import TerminalBar from '../components/TerminalBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const allProjects = (await getCollection('projects')).sort((a, b) => {
	const flagshipDelta = Number(b.data.flagship) - Number(a.data.flagship);
	if (flagshipDelta !== 0) return flagshipDelta;
	const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return db - da;
});

const githubLink = SOCIAL_LINKS.find((link) => link.label === 'GitHub');

function getTags(tagString: string | undefined, limit = 3) {
	return tagString ? tagString.split(',').map((tag: string) => tag.trim()).slice(0, limit) : [];
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Nav />
		<TerminalBar />

		<main>
			<section class="hero-section">
				<div class="container">
					<div class="hero-panel">
						<p class="eyebrow">Arthur Wheildon / AI Systems Developer</p>
						<h1 class="hero-title">Software for messy reality.</h1>
						<p class="hero-description">
							Structured LLM workflows, secure native apps, and product-grade tooling for founders and dev teams shipping under real constraints.
						</p>
						<div class="hero-actions">
							<a href="/contact" class="btn btn-primary">Start a Project</a>
							{githubLink && (
								<a href={githubLink.href} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">GitHub</a>
							)}
						</div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-head">
						<p class="eyebrow">Projects</p>
						<h2 class="section-title">What I've built.</h2>
					</div>
					<div class="project-grid">
						{allProjects.map((project) => (
							<a href={`/projects/${project.id}`} class="project-card">
								<p class="card-label">{project.data.flagship ? 'Flagship' : project.data.status.replace('-', ' ')}</p>
								<h3 class="card-title">{project.data.title}</h3>
								<p class="card-body">{project.data.headline ?? project.data.description}</p>
								<div class="tag-row">
									{getTags(project.data.tags).map((tag: string) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="cta-panel">
						<div>
							<p class="eyebrow">Contact</p>
							<h2 class="section-title">Let's build something.</h2>
						</div>
						<a href="/contact" class="btn btn-primary">Get in Touch</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fg-faint);
	}

	/* ── Hero ── */

	.hero-section {
		padding: 1.5rem 0 5rem;
	}

	.hero-panel {
		padding: 2.5rem 2rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
	}

	.hero-title {
		font-size: clamp(3rem, 7vw, 5.5rem);
		margin: 0 0 1.25rem;
		max-width: 14ch;
	}

	.hero-description {
		max-width: 38rem;
		font-size: 1.1rem;
		color: var(--fg-muted);
		line-height: 1.75;
		margin: 0 0 2rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.1rem;
		border-radius: 999px;
		border: none;
		text-decoration: none;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: opacity 0.15s ease, border-color 0.15s ease, color 0.15s ease;
	}

	.btn-primary {
		background: var(--accent);
		color: #0d0d0d;
	}

	.btn-primary:hover {
		color: #0d0d0d;
		opacity: 0.88;
	}

	.btn-secondary {
		background: transparent;
		color: var(--fg-muted);
		border: 1px solid var(--border);
	}

	.btn-secondary:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	/* ── Projects ── */

	.section {
		padding: 0 0 5rem;
	}

	.section-head {
		margin-bottom: 1.5rem;
	}

	.section-title {
		margin: 0;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.25rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-decoration: none;
		transition: border-color 0.15s ease, background 0.15s ease;
	}

	.project-card:hover {
		border-color: var(--border-strong);
		background: var(--surface-hover);
	}

	.card-label {
		margin: 0;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--fg-faint);
	}

	.card-title {
		margin: 0;
		font-family: 'Syne', sans-serif;
		font-size: 1.3rem;
		letter-spacing: -0.025em;
		line-height: 1.15;
		color: var(--fg);
	}

	.card-body {
		margin: 0;
		color: var(--fg-muted);
		line-height: 1.7;
		font-size: 0.95rem;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}

	.tag {
		display: inline-flex;
		padding: 0.25rem 0.5rem;
		border-radius: 6px;
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.6rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}

	/* ── CTA ── */

	.cta-panel {
		padding: 1.5rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	/* ── Responsive ── */

	@media (max-width: 980px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.hero-section {
			padding: 1rem 0 4rem;
		}

		.hero-panel {
			padding: 1.5rem 1.25rem;
		}

		.section {
			padding-bottom: 4rem;
		}

		.cta-panel {
			flex-direction: column;
			align-items: start;
		}
	}
</style>
