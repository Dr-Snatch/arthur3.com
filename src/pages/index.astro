---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';
import { projects } from '../data/projects';

const stack = ['Swift', 'SwiftUI', 'Python', 'JavaScript', 'TypeScript', 'Xcode', 'Node.js', 'Git'];

const exploring = [
	'Building AI-powered tools',
	'LLM APIs and how to build on top of them',
	'Improving as a SwiftUI developer',
	'Shipping things faster',
];

const buildLog = [
	{ hash: 'a3f2d91', date: 'Mar 2026', message: 'Experimenting with AI tool ideas. Mostly building prototypes, scrapping them, and starting again.' },
	{ hash: 'c8e1b04', date: 'Feb 2026', message: 'Working on a SwiftUI iOS app. Learning a lot about state management and navigation.' },
	{ hash: '5d9f3a7', date: 'Jan 2026', message: 'Started BSc Artificial Intelligence at Northumbria University.' },
	{ hash: 'b2a7e58', date: 'Late 2025', message: 'Learning JavaScript and TypeScript. Built a few small web projects to get the reps in.' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Nav />

		<main>

			<!-- ── HERO ── -->
			<section class="hero">
				<div class="hero-inner">

					<p class="hero-label">
						<span class="dot" aria-hidden="true"></span>
						BSc Artificial Intelligence · Northumbria University
					</p>

					<h1 class="hero-heading">Arthur —<br />AI Student &<br />App Builder.</h1>

					<p class="hero-body">
						I build iOS apps in SwiftUI, automate things in Python, and write
						JavaScript when I have to. Currently exploring how to build useful
						tools with AI. Based in the UK.
					</p>

					<div class="terminal-line" aria-live="polite">
						<span class="prompt">~$</span>
						<span id="cycling">building iOS apps in SwiftUI</span>
						<span class="cursor" aria-hidden="true"></span>
					</div>

					<div class="hero-ctas">
						<a href="#projects" class="btn-primary">View Projects</a>
						<a href="#contact" class="btn-ghost">Get in Touch</a>
					</div>
				</div>
			</section>

			<!-- ── MARQUEE ── -->
			<div class="marquee-wrap" aria-hidden="true">
				<div class="marquee-track">
					{[...stack, ...stack, ...stack].map((t) => (
						<span class="marquee-item">{t}<span class="marquee-sep"> / </span></span>
					))}
				</div>
			</div>

			<!-- ── WHAT I BUILD ── -->
			<section class="section">
				<div class="container">
					<p class="eyebrow">what i build</p>
					<div class="build-grid">
						<div class="build-col">
							<h3 class="build-title">iOS &amp; macOS Apps</h3>
							<p class="build-desc">Native apps built with SwiftUI. Mostly for myself — tools I want to exist.</p>
						</div>
						<div class="build-col">
							<h3 class="build-title">Automation Scripts</h3>
							<p class="build-desc">Python scripts that do repetitive things so I don't have to.</p>
						</div>
						<div class="build-col">
							<h3 class="build-title">Web Projects</h3>
							<p class="build-desc">JavaScript/TypeScript frontends and small web tools. Nothing fancy.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ── PROJECTS ── -->
			<section id="projects" class="section section-dark">
				<div class="container">
					<div class="section-row">
						<p class="eyebrow">projects</p>
						<a href="https://github.com/Dr-Snatch" target="_blank" rel="noopener noreferrer" class="subtle-link">
							github.com/Dr-Snatch ↗
						</a>
					</div>
					<div class="projects-grid">
						{projects.map((p, i) => (
							<div class="reveal" style={`transition-delay:${i*0.07}s`}>
								<ProjectCard {...p} />
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ── TECH STACK ── -->
			<section class="section">
				<div class="container">
					<p class="eyebrow">tech stack</p>
					<div class="stack-list reveal">
						{stack.map((t) => <span class="stack-item">{t}</span>)}
					</div>
				</div>
			</section>

			<!-- ── CURRENTLY EXPLORING ── -->
			<section class="section section-dark">
				<div class="container">
					<p class="eyebrow">currently exploring</p>
					<ul class="explore-list">
						{exploring.map((item, i) => (
							<li class="explore-item reveal" style={`transition-delay:${i*0.07}s`}>
								<span class="explore-arrow" aria-hidden="true">→</span>
								{item}
							</li>
						))}
					</ul>
				</div>
			</section>

			<!-- ── BUILD LOG ── -->
			<section class="section" id="log">
				<div class="container">
					<p class="eyebrow">build log</p>
					<div class="gitlog">
						{buildLog.map((entry, i) => (
							<div class="commit reveal" style={`transition-delay:${i*0.07}s`}>
								<div class="commit-left">
									<code class="commit-hash">{entry.hash}</code>
									<span class="commit-date">{entry.date}</span>
								</div>
								<p class="commit-msg">{entry.message}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ── PHILOSOPHY ── -->
			<section class="section section-dark">
				<div class="container">
					<p class="philosophy">"I build things to understand them."</p>
				</div>
			</section>

			<!-- ── CONTACT ── -->
			<section id="contact" class="section">
				<div class="container">
					<h2 class="contact-heading">Get in touch.</h2>
					<p class="contact-sub">GitHub, LinkedIn, or email. No fluff.</p>
					<div class="contact-links">
						{SOCIAL_LINKS.map((link) => {
							const isEmail = link.href.startsWith('mailto:');
							return (
								<a
									href={link.href}
									target={isEmail ? undefined : '_blank'}
									rel={isEmail ? undefined : 'noopener noreferrer'}
									class="contact-link"
								>
									{link.label}
									<span class="contact-arrow" aria-hidden="true">↗</span>
								</a>
							);
						})}
					</div>
				</div>
			</section>

		</main>

		<Footer />
	</body>
</html>

<script>
	const phrases = [
		'building iOS apps in SwiftUI',
		'automating things in Python',
		'experimenting with LLM APIs',
		'studying AI at Northumbria',
		'writing JavaScript when I have to',
		'shipping something new',
	];
	let i = 0;
	const el = document.getElementById('cycling');
	if (el) {
		setInterval(() => {
			el.style.opacity = '0';
			setTimeout(() => {
				i = (i + 1) % phrases.length;
				el.textContent = phrases[i];
				el.style.opacity = '1';
			}, 220);
		}, 3000);
	}

	const obs = new IntersectionObserver(
		(entries) => entries.forEach((e) => {
			if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
		}),
		{ threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
	);
	document.addEventListener('DOMContentLoaded', () => {
		document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
	});
</script>

<style>
	body { padding-top: 0; }
	main { width: 100%; max-width: 100%; margin: 0; padding: 0; }

	.container {
		max-width: 1060px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.reveal {
		opacity: 0;
		transform: translateY(18px);
		transition: opacity 0.5s ease, transform 0.5s ease;
	}
	.reveal.visible { opacity: 1; transform: translateY(0); }

	/* ── Eyebrow ── */
	.eyebrow {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255,255,255,0.3);
		margin: 0 0 1.75rem 0;
	}

	/* ── Buttons ── */
	.btn-primary {
		display: inline-block;
		padding: 0.7rem 1.6rem;
		background: #6366F1;
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.875rem;
		transition: background 0.2s ease, transform 0.15s ease;
	}
	.btn-primary:hover { background: #4F46E5; color: #fff; transform: translateY(-1px); }

	.btn-ghost {
		display: inline-block;
		padding: 0.7rem 1.6rem;
		background: transparent;
		color: rgba(255,255,255,0.6);
		text-decoration: none;
		border-radius: 8px;
		font-family: 'Inter', sans-serif;
		font-weight: 500;
		font-size: 0.875rem;
		border: 1px solid rgba(255,255,255,0.12);
		transition: color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
	}
	.btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.3); transform: translateY(-1px); }

	/* ── HERO ── */
	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding: 9rem 2rem 6rem;
	}

	.hero-inner {
		max-width: 1060px;
		margin: 0 auto;
		width: 100%;
	}

	.hero-label {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		color: rgba(255,255,255,0.38);
		margin: 0 0 2rem 0;
		letter-spacing: 0.05em;
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #4ade80;
		box-shadow: 0 0 7px rgba(74,222,128,0.7);
		animation: pulse 2.5s ease-in-out infinite;
		flex-shrink: 0;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.25; }
	}

	.hero-heading {
		font-family: 'Syne', sans-serif;
		font-size: clamp(3rem, 8.5vw, 7rem);
		font-weight: 800;
		line-height: 1.0;
		letter-spacing: -0.04em;
		color: #fff;
		margin: 0 0 2rem 0;
	}

	.hero-body {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		line-height: 1.7;
		color: rgba(255,255,255,0.55);
		max-width: 500px;
		margin: 0 0 2rem 0;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: 2.5rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.82rem;
	}

	.prompt { color: #6366F1; user-select: none; }

	#cycling {
		color: rgba(255,255,255,0.65);
		transition: opacity 0.22s ease;
	}

	.cursor {
		display: inline-block;
		width: 8px;
		height: 1em;
		background: rgba(99,102,241,0.75);
		border-radius: 1px;
		animation: blink 1.1s step-end infinite;
		vertical-align: text-bottom;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

	/* ── MARQUEE ── */
	.marquee-wrap {
		border-top: 1px solid rgba(255,255,255,0.07);
		border-bottom: 1px solid rgba(255,255,255,0.07);
		overflow: hidden;
		padding: 0.65rem 0;
	}

	.marquee-track {
		display: flex;
		width: max-content;
		animation: scroll 45s linear infinite;
	}

	.marquee-item {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: rgba(255,255,255,0.28);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.marquee-sep {
		color: rgba(99,102,241,0.35);
		margin: 0 0.3rem;
	}

	@keyframes scroll {
		from { transform: translateX(0); }
		to   { transform: translateX(-33.333%); }
	}

	/* ── SECTIONS ── */
	.section { padding: 6rem 0; }
	.section-dark { background: #111118; }

	.section-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.section-row .eyebrow { margin-bottom: 1.75rem; }

	.subtle-link {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: rgba(255,255,255,0.28);
		text-decoration: none;
		letter-spacing: 0.05em;
		transition: color 0.2s ease;
	}
	.subtle-link:hover { color: rgba(255,255,255,0.65); }

	/* ── WHAT I BUILD ── */
	.build-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 1px solid rgba(255,255,255,0.08);
	}

	.build-col {
		padding: 2rem 2rem 2rem 0;
		border-right: 1px solid rgba(255,255,255,0.08);
	}
	.build-col:last-child { border-right: none; padding-right: 0; }
	.build-col:not(:first-child) { padding-left: 2rem; }

	.build-title {
		font-family: 'Syne', sans-serif;
		font-size: 1rem;
		font-weight: 700;
		color: #fff;
		margin: 0 0 0.6rem 0;
	}

	.build-desc {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: rgba(255,255,255,0.45);
		line-height: 1.65;
		margin: 0;
	}

	/* ── PROJECTS ── */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
		gap: 1rem;
		margin-top: 0;
	}

	/* ── TECH STACK ── */
	.stack-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.stack-item {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		padding: 0.35rem 0.9rem;
		border: 1px solid rgba(255,255,255,0.09);
		border-radius: 6px;
		color: rgba(255,255,255,0.6);
		background: rgba(255,255,255,0.02);
		transition: color 0.2s ease, border-color 0.2s ease;
		cursor: default;
	}
	.stack-item:hover { color: #fff; border-color: rgba(99,102,241,0.4); }

	/* ── CURRENTLY EXPLORING ── */
	.explore-list { list-style: none; margin: 0; padding: 0; }

	.explore-item {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255,255,255,0.06);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.85rem;
		color: rgba(255,255,255,0.65);
	}

	.explore-arrow { color: #6366F1; font-size: 0.8rem; flex-shrink: 0; }

	/* ── BUILD LOG ── */
	.gitlog { display: flex; flex-direction: column; }

	.commit {
		display: grid;
		grid-template-columns: 170px 1fr;
		gap: 2.5rem;
		padding: 1.2rem 0;
		border-bottom: 1px solid rgba(255,255,255,0.06);
		align-items: start;
	}

	.commit-left { display: flex; flex-direction: column; gap: 0.25rem; }

	.commit-hash {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.73rem;
		color: #6366F1;
		letter-spacing: 0.06em;
		background: none;
		padding: 0;
	}

	.commit-date {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		color: rgba(255,255,255,0.28);
	}

	.commit-msg {
		font-family: 'Inter', sans-serif;
		font-size: 0.88rem;
		color: rgba(255,255,255,0.65);
		line-height: 1.65;
		margin: 0;
	}

	/* ── PHILOSOPHY ── */
	.philosophy {
		font-family: 'Syne', sans-serif;
		font-size: clamp(1.4rem, 3vw, 2.2rem);
		font-weight: 700;
		color: rgba(255,255,255,0.85);
		letter-spacing: -0.02em;
		line-height: 1.25;
		margin: 0;
	}

	/* ── CONTACT ── */
	.contact-heading {
		font-family: 'Syne', sans-serif;
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		color: #fff;
		margin: 0 0 0.5rem 0;
	}

	.contact-sub {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: rgba(255,255,255,0.3);
		margin: 0 0 2rem 0;
		letter-spacing: 0.02em;
	}

	.contact-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }

	.contact-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.6rem 1.25rem;
		background: rgba(255,255,255,0.03);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 8px;
		color: rgba(255,255,255,0.65);
		text-decoration: none;
		font-family: 'Inter', sans-serif;
		font-size: 0.875rem;
		font-weight: 500;
		transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}
	.contact-link:hover {
		color: #fff;
		border-color: rgba(99,102,241,0.4);
		background: rgba(99,102,241,0.06);
	}

	.contact-arrow { font-size: 0.72rem; color: rgba(255,255,255,0.22); transition: color 0.2s ease; }
	.contact-link:hover .contact-arrow { color: #6366F1; }

	/* ── Responsive ── */
	@media (max-width: 860px) {
		.build-grid { grid-template-columns: 1fr; }
		.build-col {
			border-right: none;
			border-bottom: 1px solid rgba(255,255,255,0.08);
			padding: 1.75rem 0;
		}
		.build-col:last-child { border-bottom: none; }
		.build-col:not(:first-child) { padding-left: 0; }
	}

	@media (max-width: 640px) {
		.hero { padding: 8rem 1.5rem 5rem; min-height: 90vh; }
		.container { padding: 0 1.5rem; }
		.section { padding: 4.5rem 0; }
		.commit { grid-template-columns: 1fr; gap: 0.3rem; }
		.contact-links { flex-direction: column; }
	}

	@media (prefers-reduced-motion: reduce) {
		.reveal { opacity: 1; transform: none; transition: none; }
		.cursor { animation: none; opacity: 1; }
		.dot { animation: none; }
		.marquee-track { animation: none; }
	}
</style>
