---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import TerminalBar from '../components/TerminalBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const allProjects = (await getCollection('projects')).sort((a, b) => {
	const flagshipDelta = Number(b.data.flagship) - Number(a.data.flagship);
	if (flagshipDelta !== 0) return flagshipDelta;
	const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return db - da;
});

const githubLink = SOCIAL_LINKS.find((link) => link.label === 'GitHub');

function getTags(tagString: string | undefined, limit = 3) {
	return tagString ? tagString.split(',').map((tag: string) => tag.trim()).slice(0, limit) : [];
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Nav />

		<main id="main-content">
			<section class="hero-section">
				<div class="container">
					<div class="hero-panel">
						<p class="eyebrow">Arthur Wheildon / AI Systems Developer</p>
						<h1 class="hero-title">Software for messy reality.</h1>
						<p class="hero-description">
							Structured LLM workflows, secure native apps, and product-grade tooling for founders and dev teams shipping under real constraints.
						</p>
						<div class="hero-actions">
							<a href="/contact" class="btn btn-primary">Start a Project</a>
							{githubLink && (
								<a href={githubLink.href} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">GitHub</a>
							)}
						</div>
					</div>
				</div>
			</section>

			<section class="stats-section">
				<div class="container">
					<div class="stats-grid">
						<div class="stat-item">
							<div class="stat-value">AI Systems</div>
							<div class="stat-label">LLM Pipelines · Structured Output</div>
						</div>
						<div class="stat-item">
							<div class="stat-value">Native Apps</div>
							<div class="stat-label">OAuth · Keychain · SwiftUI</div>
						</div>
						<div class="stat-item">
							<div class="stat-value">Automation</div>
							<div class="stat-label">APIs · CLI · Developer Tools</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-head">
						<p class="eyebrow">Projects</p>
						<h2 class="section-title">What I've built.</h2>
					</div>
					<div class="project-grid">
						{allProjects.map((project) => (
							<a href={`/projects/${project.id}`} class="project-card">
								<p class="card-label">{project.data.flagship ? 'Flagship' : project.data.status.replace('-', ' ')}</p>
								<h3 class="card-title">{project.data.title}</h3>
								<p class="card-body">{project.data.headline ?? project.data.description}</p>
								<div class="tag-row">
									{getTags(project.data.tags).map((tag: string) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="cta-panel">
						<div>
							<p class="eyebrow">Ready to Build?</p>
							<h2 class="section-title">Let's discuss your project.</h2>
							<p class="cta-description">Available for AI systems, native apps, and technical product work that needs to survive real constraints.</p>
						</div>
						<a href="/contact" class="btn btn-primary">Start a Conversation</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<TerminalBar />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.eyebrow {
		margin: 0 0 var(--space-2);
		font-family: 'JetBrains Mono', monospace;
		font-size: var(--text-xs);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
		font-weight: 600;
	}

	/* ── Hero ── */

	.hero-section {
		padding: 4rem 0 var(--space-8);
	}

	.hero-panel {
		padding: var(--space-5) var(--space-4);
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
	}

	.hero-title {
		font-size: clamp(var(--text-4xl), 7vw, var(--text-5xl));
		margin: 0 0 var(--space-3);
		max-width: 14ch;
		line-height: var(--leading-tight);
		letter-spacing: -0.04em;
	}

	.hero-description {
		max-width: 42rem;
		font-size: var(--text-lg);
		color: var(--fg-secondary);
		line-height: var(--leading-relaxed);
		margin: 0 0 var(--space-4);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1rem 2rem;
		min-height: 44px;
		min-width: 120px;
		border-radius: 999px;
		border: none;
		text-decoration: none;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: opacity 0.15s ease, border-color 0.15s ease, color 0.15s ease;
	}

	.btn-primary {
		background: var(--accent);
		color: #0d0d0d;
	}

	.btn-primary:hover {
		color: #0d0d0d;
		opacity: 0.88;
	}

	.btn-secondary {
		background: transparent;
		color: var(--fg-secondary);
		border: 1px solid var(--border);
	}

	.btn-secondary:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	/* Focus states for buttons */
	.btn-primary:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		box-shadow: 0 0 0 4px rgba(61, 214, 140, 0.2);
	}

	.btn-secondary:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		border-color: var(--accent);
	}

	/* ── Stats Section ── */
	.stats-section {
		padding: 0 0 var(--space-8);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-2);
	}

	.stat-item {
		padding: var(--space-3);
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-align: center;
	}

	.stat-value {
		font-family: 'Syne', sans-serif;
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--accent);
		margin-bottom: var(--space-1);
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-family: 'JetBrains Mono', monospace;
		font-size: var(--text-xs);
		color: var(--fg-tertiary);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	/* ── Projects ── */

	.section {
		padding: 0 0 5rem;
	}

	.section-head {
		margin-bottom: 1.5rem;
	}

	.section-title {
		margin: 0;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-3);
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-decoration: none;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		overflow: hidden;
	}

	/* Add subtle gradient overlay on hover */
	.project-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(
			circle at top left,
			rgba(61, 214, 140, 0.04),
			transparent 60%
		);
		opacity: 0;
		transition: opacity 0.3s ease;
		pointer-events: none;
	}

	.project-card:hover {
		border-color: var(--accent-border);
		background: var(--surface-hover);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
	}

	.project-card:hover::before {
		opacity: 1;
	}

	/* Focus state for project cards */
	.project-card:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		border-color: var(--accent);
	}

	.card-label {
		margin: 0;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
	}

	.card-title {
		margin: 0;
		font-family: 'Syne', sans-serif;
		font-size: 1.3rem;
		letter-spacing: -0.025em;
		line-height: 1.15;
		color: var(--fg);
	}

	.card-body {
		margin: 0;
		color: var(--fg-secondary);
		line-height: 1.7;
		font-size: 0.95rem;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}

	.tag {
		display: inline-flex;
		padding: 0.25rem 0.5rem;
		border-radius: 6px;
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.6rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}

	/* ── CTA ── */

	.cta-panel {
		padding: 2rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.cta-description {
		margin: 0.5rem 0 0;
		color: var(--fg-secondary);
		line-height: 1.75;
		max-width: 38rem;
		font-size: 0.95rem;
	}

	/* ── Responsive ── */

	/* Tablet: 2 columns */
	@media (min-width: 640px) and (max-width: 1024px) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* Mobile: 1 column */
	@media (max-width: 639px) {
		.project-grid {
			grid-template-columns: 1fr;
			gap: var(--space-2);
		}

		.stats-grid {
			grid-template-columns: 1fr;
			gap: var(--space-2);
		}

		.stats-section {
			padding-bottom: var(--space-6);
		}
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.hero-section {
			padding: 3rem 0 var(--space-6);
		}

		.hero-panel {
			padding: var(--space-3) var(--space-2);
		}

		.section {
			padding-bottom: var(--space-6);
		}

		.cta-panel {
			flex-direction: column;
			align-items: start;
		}

		.btn {
			padding: 1.2rem 2.5rem;
			min-height: 48px;
			font-size: 0.8rem;
		}

		.project-card {
			padding: var(--space-3);
			min-height: 120px;
		}
	}
</style>
