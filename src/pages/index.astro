---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import TerminalBar from '../components/TerminalBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const allProjects = await getCollection('projects');
const beatMapProject = allProjects.find((project) => project.id === 'beatmap');
const supportingProjects = allProjects
	.filter((project) => project.id !== 'beatmap')
	.sort((a, b) => {
		const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
		const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
		return db - da;
	})
	.slice(0, 2);

const allNotes = (await getCollection('lab')).sort((a, b) => {
	const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return db - da;
});

const highlightedNotes = ['shazam-benchmarks', 'prompt-sandwich']
	.map((id) => allNotes.find((note) => note.id === id))
	.filter(Boolean);

const homeNotes = highlightedNotes.length === 2 ? highlightedNotes : allNotes.slice(0, 2);

const heroSignals = [
	'BSc Artificial Intelligence at Northumbria',
	'Swift, Python, LLM systems',
	'Built for recruiters and founders',
];

const buildAreas = [
	{
		title: 'AI systems',
		copy: 'Structured output pipelines, streaming UX, and model-driven software that stays reliable under real input.',
	},
	{
		title: 'Secure native apps',
		copy: 'Mobile products with hardened auth, durable local storage, and careful handling of lifecycle edge cases.',
	},
	{
		title: 'Product-minded tooling',
		copy: 'Developer tools and integrations that make brittle workflows repeatable, inspectable, and faster to ship.',
	},
];

const principles = [
	'Reliability over novelty',
	'Security has to survive real use',
	'Structured outputs beat vague automation',
	'Small systems should still feel like products',
];

const githubLink = SOCIAL_LINKS.find((link) => link.label === 'GitHub');

function getTags(tagString, limit = 3) {
	return tagString ? tagString.split(',').map((tag) => tag.trim()).slice(0, limit) : [];
}

const beatMapSummary = beatMapProject
	? [
			{ label: 'Problem', value: beatMapProject.data.problem },
			{ label: 'System', value: beatMapProject.data.system },
			{ label: 'Result', value: beatMapProject.data.result },
		].filter((item) => item.value)
	: [];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Nav />
		<TerminalBar />

		<main>
			<section class="hero-section">
				<div class="container hero-layout">
					<div class="hero-copy">
						<p class="eyebrow">Arthur Wheildon</p>
						<h1 class="hero-title">AI Systems Developer.</h1>
						<p class="hero-description">
							Building inventive, reliable, and scalable AI solutions, secure native apps, and tools that still hold up once the demo ends.
						</p>
						<div class="hero-actions">
							<a href="/contact" class="btn btn-primary">Let's Work</a>
							<a href="#beatmap" class="btn btn-secondary">See BeatMap</a>
						</div>
						<div class="signal-row">
							{heroSignals.map((signal) => (
								<span class="signal-pill">{signal}</span>
							))}
						</div>
					</div>

					<div class="hero-rail">
						<article class="hero-panel hero-panel-strong">
							<p class="panel-label">Who I am</p>
							<h2 class="panel-title">A product-minded builder working across AI, native apps, and automation.</h2>
							<p class="panel-copy">
								The goal is not just to prototype ideas quickly. It is to make them secure, robust, and usable enough to keep working under real constraints.
							</p>
						</article>

						<article class="hero-panel">
							<p class="panel-label">Desktop USP</p>
							<p class="panel-copy">
								The terminal is still here as a utility for people who want to inspect the site like a filesystem. On mobile it stays tucked away until you ask for it.
							</p>
							<div class="command-row">
								<span class="command-chip">help</span>
								<span class="command-chip">projects</span>
								<span class="command-chip">contact</span>
							</div>
						</article>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-head">
						<p class="eyebrow">Systems I Build</p>
						<h2 class="section-title">Clear product positioning instead of a tool list.</h2>
					</div>
					<div class="area-grid">
						{buildAreas.map((area) => (
							<article class="area-card">
								<h3 class="area-title">{area.title}</h3>
								<p class="area-copy">{area.copy}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			{beatMapProject && (
				<section class="section flagship-section" id="beatmap">
					<div class="container flagship-grid">
						<div class="flagship-copy">
							<p class="eyebrow">Flagship Product</p>
							<span class="product-badge">BeatMap · iOS</span>
							<h2 class="section-title">Music journaling with hardened Spotify auth and durable on-device data.</h2>
							<p class="flagship-description">
								{beatMapProject.data.headline ?? beatMapProject.data.description}
							</p>
							<div class="summary-grid">
								{beatMapSummary.map((item) => (
									<article class="summary-card">
										<p class="summary-label">{item.label}</p>
										<p class="summary-copy">{item.value}</p>
									</article>
								))}
							</div>
							<div class="hero-actions">
								<a href={`/projects/${beatMapProject.id}`} class="btn btn-primary">Read Case Study</a>
								{beatMapProject.data.repoUrl && (
									<a href={beatMapProject.data.repoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
										GitHub
									</a>
								)}
							</div>
						</div>

						<div class="shot-rail">
							<div class="shot-stack">
								<img
									src="/beatmap-shot-map.svg"
									alt="BeatMap placeholder showing a music map and secure auth card"
									class="product-shot product-shot-primary"
									loading="eager"
								/>
								<img
									src="/beatmap-shot-journal.svg"
									alt="BeatMap placeholder showing a journal entry and insights cards"
									class="product-shot product-shot-secondary"
								/>
							</div>
							<article class="proof-card">
								<p class="proof-label">What matters</p>
								<ul class="proof-list">
									<li>OAuth 2.0 PKCE built without third-party auth libraries</li>
									<li>Core Data migration and durable offline-friendly storage</li>
									<li>ShazamKit benchmarking that directly shaped the UX</li>
								</ul>
							</article>
						</div>
					</div>
				</section>
			)}

			<section class="section">
				<div class="container work-layout">
					<div class="section-head section-head-inline">
						<div>
							<p class="eyebrow">More Work</p>
							<h2 class="section-title">Supporting systems and technical notes.</h2>
						</div>
						<a href="/projects" class="text-link">Browse all projects ↗</a>
					</div>

					<div class="work-grid">
						{supportingProjects.map((project) => (
							<article class="project-card">
								<div class="card-top">
									<p class="card-kicker">{project.data.status.replace('-', ' ')}</p>
									<p class="card-title">{project.data.title}</p>
								</div>
								<p class="card-copy">{project.data.headline ?? project.data.description}</p>
								<div class="card-tag-row">
									{getTags(project.data.tags).map((tag) => (
										<span class="card-tag">{tag}</span>
									))}
								</div>
								<a href={`/projects/${project.id}`} class="text-link">Read case study ↗</a>
							</article>
						))}
					</div>

					<div class="notes-grid">
						{homeNotes.map((note) => (
							<article class="note-card">
								<p class="card-kicker">{note.data.status}</p>
								<p class="card-title">{note.data.title}</p>
								<p class="card-copy">{note.data.result ?? note.data.description}</p>
								<a href={`/lab/${note.id}`} class="text-link">Read note ↗</a>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-head">
						<p class="eyebrow">Engineering Principles</p>
						<h2 class="section-title">Simple standards that keep the work serious.</h2>
					</div>
					<div class="principles-grid">
						{principles.map((principle) => (
							<div class="principle-card">{principle}</div>
						))}
					</div>
				</div>
			</section>

			<section class="section cta-section">
				<div class="container">
					<div class="cta-panel">
						<div>
							<p class="eyebrow">Contact</p>
							<h2 class="section-title">Recruiters, founders, and teams building AI products.</h2>
							<p class="cta-copy">
								Best fit: AI systems, secure mobile experiences, and technical product work that needs careful engineering rather than shallow demos.
							</p>
						</div>
						<div class="hero-actions">
							<a href="/contact" class="btn btn-primary">Let's Work</a>
							{githubLink && (
								<a href={githubLink.href} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
									GitHub
								</a>
							)}
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section {
		padding: 0 0 5.5rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted-faint);
	}

	.hero-section {
		padding: 1.25rem 0 4rem;
	}

	.hero-layout,
	.flagship-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: 1.5rem;
		align-items: start;
	}

	.hero-title {
		max-width: 13ch;
		font-size: clamp(3rem, 7vw, 5.5rem);
		margin-bottom: 1.2rem;
	}

	.hero-description,
	.flagship-description,
	.panel-copy,
	.area-copy,
	.card-copy,
	.summary-copy,
	.cta-copy {
		color: var(--muted-soft);
		line-height: 1.75;
	}

	.hero-description {
		max-width: 42rem;
		font-size: 1.04rem;
		margin-bottom: 1.6rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.btn,
	.text-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, color 0.18s ease;
	}

	.btn {
		padding: 0.9rem 1.2rem;
		border-radius: 999px;
		font-size: 0.92rem;
		font-weight: 600;
	}

	.btn-primary {
		background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.95), rgba(var(--accent-blue-rgb), 0.78));
		color: #04101f;
		box-shadow: 0 16px 36px rgba(var(--accent-rgb), 0.18);
	}

	.btn-primary:hover {
		color: #04101f;
		transform: translateY(-1px);
	}

	.btn-secondary {
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.04);
		color: var(--fg);
	}

	.btn-secondary:hover,
	.text-link:hover {
		transform: translateY(-1px);
		color: var(--fg);
		border-color: rgba(var(--accent-rgb), 0.24);
	}

	.signal-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-top: 1.35rem;
	}

	.signal-pill,
	.command-chip,
	.card-tag,
	.product-badge {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.signal-pill {
		padding: 0.55rem 0.8rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: rgba(var(--fg-rgb), 0.84);
	}

	.hero-rail {
		display: grid;
		gap: 1rem;
	}

	.hero-panel,
	.area-card,
	.summary-card,
	.project-card,
	.note-card,
	.proof-card,
	.cta-panel {
		border-radius: 28px;
		border: 1px solid var(--border);
		background: linear-gradient(180deg, rgba(13, 29, 55, 0.95), rgba(8, 18, 34, 0.96));
		box-shadow: var(--box-shadow);
	}

	.hero-panel,
	.area-card,
	.project-card,
	.note-card,
	.proof-card {
		padding: 1.35rem;
	}

	.hero-panel-strong {
		background:
			radial-gradient(circle at top right, rgba(var(--accent-rgb), 0.2), transparent 40%),
			linear-gradient(180deg, rgba(15, 34, 66, 0.98), rgba(8, 18, 34, 0.96));
	}

	.panel-label,
	.summary-label,
	.proof-label,
	.card-kicker {
		margin: 0 0 0.65rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted-faint);
	}

	.panel-title,
	.card-title,
	.area-title {
		margin: 0 0 0.75rem;
		font-family: 'Syne', sans-serif;
		font-size: 1.45rem;
		letter-spacing: -0.04em;
	}

	.command-row,
	.card-tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.command-row {
		margin-top: 1rem;
	}

	.command-chip {
		padding: 0.4rem 0.65rem;
		border-radius: 999px;
		background: rgba(var(--accent-blue-rgb), 0.1);
		color: rgba(var(--fg-rgb), 0.84);
	}

	.section-head {
		margin-bottom: 1.35rem;
	}

	.section-head-inline {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.section-title {
		max-width: 14ch;
		font-size: clamp(2rem, 4vw, 3.2rem);
	}

	.area-grid,
	.work-grid,
	.notes-grid,
	.principles-grid {
		display: grid;
		gap: 1rem;
	}

	.area-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.flagship-section {
		padding-bottom: 5.75rem;
	}

	.product-badge {
		display: inline-flex;
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--accent-rgb), 0.12);
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.summary-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
		margin: 1.4rem 0 1.6rem;
	}

	.summary-card {
		padding: 1rem;
	}

	.shot-rail {
		display: grid;
		gap: 1rem;
	}

	.shot-stack {
		position: relative;
		min-height: 36rem;
	}

	.product-shot {
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.34);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.product-shot-primary {
		width: min(26rem, 100%);
	}

	.product-shot-secondary {
		position: absolute;
		right: 0;
		bottom: 0;
		width: min(18rem, 56%);
	}

	.proof-list {
		margin: 0;
		padding-left: 1.1rem;
		color: var(--muted-soft);
	}

	.proof-list li + li {
		margin-top: 0.65rem;
	}

	.work-layout {
		display: grid;
		gap: 1rem;
	}

	.work-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.notes-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.card-copy {
		margin-bottom: 1rem;
	}

	.card-tag {
		padding: 0.35rem 0.55rem;
		border-radius: 999px;
		background: rgba(var(--accent-rgb), 0.08);
		color: var(--accent);
	}

	.text-link {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.74rem;
		color: rgba(var(--fg-rgb), 0.8);
	}

	.principles-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.principle-card {
		padding: 1rem 1.1rem;
		border-radius: 20px;
		border: 1px solid rgba(var(--accent-rgb), 0.12);
		background: rgba(255, 255, 255, 0.03);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		line-height: 1.7;
		color: rgba(var(--fg-rgb), 0.86);
	}

	.cta-panel {
		padding: 1.6rem;
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.cta-copy {
		max-width: 38rem;
		margin: 0;
	}

	@media (max-width: 980px) {
		.hero-layout,
		.flagship-grid,
		.area-grid,
		.work-grid,
		.notes-grid,
		.principles-grid,
		.summary-grid,
		.cta-panel {
			grid-template-columns: 1fr;
		}

		.hero-layout,
		.flagship-grid {
			grid-template-columns: 1fr;
		}

		.section-head-inline,
		.cta-panel {
			align-items: start;
			flex-direction: column;
		}

		.shot-stack {
			min-height: auto;
			display: grid;
			gap: 1rem;
		}

		.product-shot-secondary {
			position: static;
			width: min(22rem, 100%);
			justify-self: end;
		}
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.section {
			padding-bottom: 4.5rem;
		}

		.hero-section {
			padding: 0.75rem 0 3rem;
		}

		.hero-title,
		.section-title {
			max-width: none;
		}

		.hero-description {
			font-size: 1rem;
		}

		.hero-panel,
		.area-card,
		.summary-card,
		.project-card,
		.note-card,
		.proof-card,
		.cta-panel {
			border-radius: 22px;
		}

		.hero-panel,
		.area-card,
		.project-card,
		.note-card,
		.proof-card,
		.cta-panel {
			padding: 1.1rem;
		}

		.product-shot-primary,
		.product-shot-secondary {
			width: 100%;
			justify-self: stretch;
		}
	}
</style>
