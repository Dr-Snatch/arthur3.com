---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';
import { projects } from '../data/projects';

const stack = [
	'Swift', 'SwiftUI', 'Xcode', 'Core Data', 'Python',
	'JavaScript', 'TypeScript', 'Git', 'Node.js', 'iOS SDK', 'Claude API', 'Ollama',
];

const exploring = [
	'Building AI-powered tools on top of LLM APIs',
	'Improving as a SwiftUI developer — persistence, auth, background tasks',
	'Structured data extraction from unstructured AI output',
	'Learning how to ship faster and more consistently',
	'Reading about how modern AI systems are actually built',
];

const buildLog = [
	{ hash: 'f3a91cc', date: 'Mar 2026', message: 'RPtext: character creation, combat, stats, inventory, NPC memory, and faction standings all functional.' },
	{ hash: 'b7e24d1', date: 'Mar 2026', message: 'BeatMap v1.1.0: Core Data migration, AirDrop sharing, and Spotify integration shipped.' },
	{ hash: '9c1f8a3', date: 'Feb 2026', message: 'BeatMap: ShazamKit integration and OAuth 2.0 PKCE auth — the hard parts are done.' },
	{ hash: '5d3b70e', date: 'Jan 2026', message: 'First semester of BSc Artificial Intelligence at Northumbria underway.' },
	{ hash: 'a2e95f4', date: 'Late 2025', message: 'Building with JavaScript and TypeScript. First proper web projects.' },
	{ hash: 'c8d1240', date: 'Mid 2025', message: 'Started learning SwiftUI. BeatMap concept begins.' },
];

const writingPosts = [
	{
		title: 'What I learned migrating BeatMap from UserDefaults to Core Data',
		date: 'Coming soon',
		desc: 'Why the migration was harder than expected and what I\'d do differently.',
	},
	{
		title: 'Why I chose SwiftUI over UIKit as a beginner',
		date: 'Coming soon',
		desc: 'The tradeoffs I didn\'t fully understand until I was deep in both.',
	},
	{
		title: 'Getting structured JSON out of streaming AI responses without breaking immersion',
		date: 'Coming soon',
		desc: 'The XML sandwich architecture I use in RPtext and why it works.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Nav />

		<main>

			<!-- ── HERO ── -->
			<section class="hero">
				<div class="hero-inner">
					<p class="hero-label">
						<span class="dot" aria-hidden="true"></span>
						BSc Artificial Intelligence · Northumbria University · Newcastle, UK
					</p>

					<h1 class="hero-heading">Arthur —<br />AI Student &<br />App Builder.</h1>

					<p class="hero-body">
						I build iOS and macOS apps in SwiftUI, automate things in Python,
						and write JavaScript when I have to. Currently working on BeatMap
						and RPtext. Learning in public.
					</p>

					<div class="terminal-line" aria-live="polite">
						<span class="t-prompt">~$</span>
						<span id="cycling">building BeatMap — music journaling for iOS</span>
						<span class="t-cursor" aria-hidden="true"></span>
					</div>

					<div class="hero-ctas">
						<a href="#projects" class="btn-primary">View Projects</a>
						<a href="#contact" class="btn-ghost">Get in Touch</a>
					</div>
				</div>
			</section>

			<!-- ── MARQUEE ── -->
			<div class="marquee-wrap" aria-hidden="true">
				<div class="marquee-track">
					{[...stack, ...stack, ...stack].map((t) => (
						<span class="marquee-item">{t}<span class="msep"> / </span></span>
					))}
				</div>
			</div>

			<!-- ── WHAT I BUILD ── -->
			<section class="section">
				<div class="container">
					<p class="eyebrow">what i build</p>
					<div class="build-grid">
						<div class="build-col">
							<h3 class="build-title">iOS &amp; macOS Apps</h3>
							<p class="build-desc">Native apps built with SwiftUI. Currently deep in Core Data, MapKit, third-party API auth, and AI integration.</p>
						</div>
						<div class="build-col">
							<h3 class="build-title">Automation &amp; Scripts</h3>
							<p class="build-desc">Python scripts that handle repetitive tasks. Usually built to solve something annoying.</p>
						</div>
						<div class="build-col">
							<h3 class="build-title">Web Projects</h3>
							<p class="build-desc">JavaScript and TypeScript. Frontends, small tools, experiments.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ── FEATURED PROJECTS ── -->
			<section id="projects" class="section section-dark">
				<div class="container">
					<p class="eyebrow">featured projects</p>

					<div class="featured-grid">

						<!-- BeatMap -->
						<article class="feat-card reveal">
							<div class="feat-header">
								<div>
									<span class="feat-name">BeatMap</span>
									<p class="feat-tagline">Music journaling for iOS. Tied to songs, places, and how you actually felt.</p>
								</div>
								<span class="feat-status">● In Progress — v1.1.0</span>
							</div>

							<p class="feat-desc">
								BeatMap lets you create diary entries linked to songs, your location,
								and personal metrics — mood, nostalgia, energy. It pulls live data from
								Spotify, identifies songs via ShazamKit, and builds an insights dashboard
								that surfaces patterns in your listening history over time.
							</p>

							<div class="feat-callout">
								<span class="callout-prefix">// </span>The hardest part: managing competing audio sessions between ShazamKit
								and AVFoundation while keeping OAuth token refresh completely invisible to the user.
							</div>

							<div class="feat-tags">
								{['Swift', 'SwiftUI', 'Core Data', 'MapKit', 'ShazamKit', 'Spotify API', 'OAuth 2.0 PKCE', 'AVFoundation', 'CryptoKit', 'iOS Keychain'].map((t) => (
									<span class="feat-tag">{t}</span>
								))}
							</div>

							<a href="https://github.com/Dr-Snatch" target="_blank" rel="noopener noreferrer" class="feat-link">
								GitHub (coming soon) ↗
							</a>
						</article>

						<!-- RPtext -->
						<article class="feat-card reveal" style="transition-delay: 0.08s">
							<div class="feat-header">
								<div>
									<span class="feat-name">RPtext</span>
									<p class="feat-tagline">An AI-powered text RPG. Living world, real consequences, no scripted content.</p>
								</div>
								<span class="feat-status">● In Progress — Core systems functional</span>
							</div>

							<p class="feat-desc">
								RPtext is a native macOS app where AI generates the entire narrative in
								real time. No scripted content — the world reacts to what you do and how
								you say it. Vague or lazy input gets punished. Thoughtful play gets rewarded.
								NPCs remember you. Factions track your reputation.
							</p>

							<div class="feat-callout">
								<span class="callout-prefix">// </span>Reliable structured data exchange via hidden JSON blocks inside AI narrative
								responses — XML sandwich architecture for better model attention, with multi-fallback
								parsing so the game never breaks mid-session.
							</div>

							<div class="feat-tags">
								{['Swift', 'SwiftUI', 'Claude API', 'Ollama', 'llama3.2:3b', 'JSON parsing', 'Streaming responses', 'macOS'].map((t) => (
									<span class="feat-tag">{t}</span>
								))}
							</div>

							<a href="https://github.com/Dr-Snatch" target="_blank" rel="noopener noreferrer" class="feat-link">
								GitHub (coming soon) ↗
							</a>
						</article>

					</div>
				</div>
			</section>

			<!-- ── OTHER PROJECTS ── -->
			<section class="section">
				<div class="container">
					<p class="eyebrow">other projects</p>
					<div class="other-grid">
						{projects.map((p, i) => (
							<div class="reveal" style={`transition-delay:${i*0.07}s`}>
								<ProjectCard {...p} />
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ── TECH STACK ── -->
			<section class="section section-dark">
				<div class="container">
					<p class="eyebrow">tech stack</p>
					<div class="stack-list reveal">
						{stack.map((t) => <span class="stack-item">{t}</span>)}
					</div>
				</div>
			</section>

			<!-- ── CURRENTLY EXPLORING ── -->
			<section class="section">
				<div class="container">
					<p class="eyebrow">currently exploring</p>
					<ul class="explore-list">
						{exploring.map((item, i) => (
							<li class="explore-item reveal" style={`transition-delay:${i*0.06}s`}>
								<span class="explore-arr" aria-hidden="true">→</span>
								{item}
							</li>
						))}
					</ul>
				</div>
			</section>

			<!-- ── BUILD LOG ── -->
			<section class="section section-dark" id="log">
				<div class="container">
					<p class="eyebrow">build log</p>
					<div class="gitlog">
						{buildLog.map((entry, i) => (
							<div class="commit reveal" style={`transition-delay:${i*0.06}s`}>
								<div class="commit-left">
									<code class="c-hash">{entry.hash}</code>
									<span class="c-date">{entry.date}</span>
								</div>
								<p class="c-msg">{entry.message}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ── WRITING ── -->
			<section class="section">
				<div class="container">
					<div class="writing-header">
						<p class="eyebrow">writing</p>
						<a href="/blog" class="subtle-link">All posts ↗</a>
					</div>
					<p class="writing-sub">
						Short notes, tool opinions, and devlogs. Just getting started.
					</p>
					<div class="writing-grid">
						{writingPosts.map((post, i) => (
							<a href="/blog" class="post-card reveal" style={`transition-delay:${i*0.07}s`}>
								<span class="post-date">{post.date}</span>
								<h3 class="post-title">{post.title}</h3>
								<p class="post-desc">{post.desc}</p>
								<span class="post-read">Read →</span>
							</a>
						))}
					</div>
				</div>
			</section>

			<!-- ── PHILOSOPHY ── -->
			<section class="section section-dark">
				<div class="container">
					<p class="philosophy">"I build things to understand them."</p>
				</div>
			</section>

			<!-- ── CONTACT ── -->
			<section id="contact" class="section">
				<div class="container">
					<h2 class="contact-heading">Get in touch.</h2>
					<p class="contact-sub">GitHub, LinkedIn, or email. No fluff.</p>
					<div class="contact-links">
						{SOCIAL_LINKS.map((link) => {
							const isEmail = link.href.startsWith('mailto:');
							return (
								<a
									href={link.href}
									target={isEmail ? undefined : '_blank'}
									rel={isEmail ? undefined : 'noopener noreferrer'}
									class="contact-link"
								>
									{link.label}<span class="c-arr" aria-hidden="true">↗</span>
								</a>
							);
						})}
					</div>
				</div>
			</section>

		</main>

		<Footer />
	</body>
</html>

<script>
	const phrases = [
		'building BeatMap — music journaling for iOS',
		'building RPtext — an AI text RPG for macOS',
		'automating things in Python',
		'studying AI at Northumbria University',
		'writing JavaScript when I have to',
		'learning in public',
	];
	const el = document.getElementById('cycling');
	if (el) {
		let phraseIdx = 0;
		let charIdx = 0;
		let deleting = false;

		function tick() {
			const phrase = phrases[phraseIdx];
			if (!deleting) {
				charIdx++;
				el.textContent = phrase.slice(0, charIdx);
				if (charIdx === phrase.length) {
					deleting = true;
					setTimeout(tick, 2000);
					return;
				}
				setTimeout(tick, 48);
			} else {
				charIdx--;
				el.textContent = phrase.slice(0, charIdx);
				if (charIdx === 0) {
					deleting = false;
					phraseIdx = (phraseIdx + 1) % phrases.length;
					setTimeout(tick, 400);
					return;
				}
				setTimeout(tick, 28);
			}
		}
		setTimeout(tick, 600);
	}

	const obs = new IntersectionObserver(
		(entries) => entries.forEach((e) => {
			if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
		}),
		{ threshold: 0.06, rootMargin: '0px 0px -20px 0px' }
	);
	document.addEventListener('DOMContentLoaded', () => {
		document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
	});
</script>

<style>
	body { padding-top: 0; }
	main { width: 100%; max-width: 100%; margin: 0; padding: 0; }

	.container {
		max-width: 1060px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.reveal {
		opacity: 0;
		transform: translateY(16px);
		transition: opacity 0.5s ease, transform 0.5s ease;
	}
	.reveal.visible { opacity: 1; transform: translateY(0); }

	/* ── Eyebrow ── */
	.eyebrow {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(17,17,24,0.35);
		margin: 0 0 1.75rem 0;
	}

	/* ── Buttons ── */
	.btn-primary {
		display: inline-block;
		padding: 0.7rem 1.6rem;
		background: #6366F1;
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.875rem;
		transition: background 0.2s ease, transform 0.15s ease;
	}
	.btn-primary:hover { background: #4F46E5; color: #fff; transform: translateY(-1px); }

	.btn-ghost {
		display: inline-block;
		padding: 0.7rem 1.6rem;
		background: transparent;
		color: rgba(17,17,24,0.55);
		text-decoration: none;
		border-radius: 8px;
		font-family: 'Inter', sans-serif;
		font-weight: 500;
		font-size: 0.875rem;
		border: 1px solid rgba(0,0,0,0.14);
		transition: color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
	}
	.btn-ghost:hover { color: #111118; border-color: rgba(0,0,0,0.28); transform: translateY(-1px); }

	/* ── HERO ── */
	.hero {
		display: flex;
		align-items: center;
		padding: 6rem 2rem 4rem;
	}

	.hero-inner {
		max-width: 1060px;
		margin: 0 auto;
		width: 100%;
	}

	.hero-label {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: rgba(17,17,24,0.4);
		margin: 0 0 2rem 0;
		letter-spacing: 0.05em;
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #4ade80;
		box-shadow: 0 0 7px rgba(74,222,128,0.65);
		animation: pulse 2.5s ease-in-out infinite;
		flex-shrink: 0;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50%       { opacity: 0.25; }
	}

	.hero-heading {
		font-family: 'Syne', sans-serif;
		font-size: clamp(2.2rem, 5.5vw, 4rem);
		font-weight: 800;
		line-height: 1.0;
		letter-spacing: -0.04em;
		color: #111118;
		margin: 0 0 1.5rem 0;
	}

	.hero-body {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		line-height: 1.7;
		color: rgba(17,17,24,0.55);
		max-width: 500px;
		margin: 0 0 2rem 0;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: 2.5rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.82rem;
	}

	.t-prompt { color: #6366F1; user-select: none; }

	#cycling {
		color: rgba(17,17,24,0.62);
	}

	.t-cursor {
		display: inline-block;
		width: 8px;
		height: 1em;
		background: rgba(99,102,241,0.7);
		border-radius: 1px;
		animation: blink 1.1s step-end infinite;
		vertical-align: text-bottom;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50%       { opacity: 0; }
	}

	.hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

	/* ── MARQUEE ── */
	.marquee-wrap {
		border-top: 1px solid rgba(0,0,0,0.07);
		border-bottom: 1px solid rgba(0,0,0,0.07);
		overflow: hidden;
		padding: 0.65rem 0;
	}

	.marquee-track {
		display: flex;
		width: max-content;
		animation: scroll 50s linear infinite;
	}

	.marquee-item {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		color: rgba(17,17,24,0.3);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.msep { color: rgba(99,102,241,0.3); margin: 0 0.3rem; }

	@keyframes scroll {
		from { transform: translateX(0); }
		to   { transform: translateX(-33.333%); }
	}

	/* ── SECTIONS ── */
	.section { padding: 6rem 0; }
	.section-dark { background: #F2F2F6; }

	/* ── WHAT I BUILD ── */
	.build-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 1px solid rgba(0,0,0,0.08);
	}

	.build-col {
		padding: 2rem 2rem 2rem 0;
		border-right: 1px solid rgba(0,0,0,0.08);
	}
	.build-col:last-child { border-right: none; padding-right: 0; }
	.build-col:not(:first-child) { padding-left: 2rem; }

	.build-title {
		font-family: 'Syne', sans-serif;
		font-size: 1rem;
		font-weight: 700;
		color: #111118;
		margin: 0 0 0.6rem 0;
	}

	.build-desc {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.77rem;
		color: rgba(17,17,24,0.45);
		line-height: 1.7;
		margin: 0;
	}

	/* ── FEATURED PROJECTS ── */
	.featured-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	.feat-card {
		background: #FFFFFF;
		border: 1px solid rgba(0,0,0,0.08);
		border-top: 2px solid rgba(99,102,241,0.5);
		border-radius: 14px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		transition: border-color 0.25s ease, box-shadow 0.25s ease;
	}

	.feat-card:hover {
		border-color: rgba(99,102,241,0.3);
		border-top-color: #6366F1;
		box-shadow: 0 12px 40px rgba(0,0,0,0.1);
	}

	.feat-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.feat-name {
		font-family: 'Syne', sans-serif;
		font-size: 1.5rem;
		font-weight: 800;
		color: #111118;
		letter-spacing: -0.03em;
		display: block;
		margin-bottom: 0.3rem;
	}

	.feat-tagline {
		font-family: 'Inter', sans-serif;
		font-size: 0.88rem;
		color: rgba(17,17,24,0.5);
		margin: 0;
		line-height: 1.5;
	}

	.feat-status {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.67rem;
		color: #4ade80;
		white-space: nowrap;
		letter-spacing: 0.02em;
		padding-top: 0.2rem;
		flex-shrink: 0;
	}

	.feat-desc {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		color: rgba(17,17,24,0.62);
		line-height: 1.7;
		margin: 0;
	}

	.feat-callout {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		color: rgba(17,17,24,0.45);
		line-height: 1.65;
		background: rgba(99,102,241,0.04);
		border-left: 2px solid rgba(99,102,241,0.35);
		padding: 0.75rem 1rem;
		border-radius: 0 6px 6px 0;
	}

	.callout-prefix { color: rgba(99,102,241,0.6); }

	.feat-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: auto;
	}

	.feat-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		padding: 0.2rem 0.55rem;
		background: rgba(99,102,241,0.07);
		color: #4F46E5;
