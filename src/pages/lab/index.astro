---
import { getCollection } from 'astro:content';
import SectionPage from '../../layouts/SectionPage.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const notes = await getCollection('lab');
const sorted = notes.sort((a, b) => {
	const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return db - da;
});

function getTags(tagString) {
	return tagString ? tagString.split(',').map((tag) => tag.trim()).slice(0, 3) : [];
}
---

<SectionPage title="Engineering Notes" description="Benchmarks, experiments, and technical write-ups behind the shipped work.">
	<Fragment slot="eyebrow">~/lab</Fragment>
	<Fragment slot="heading">Engineering Notes.</Fragment>
	<Fragment slot="description">
		Benchmarks, prototypes, and case-study fragments that explain how the systems on this site were tested, improved, and made more reliable.
	</Fragment>

	<section class="section">
		<div class="container">
			{sorted.length === 0 ? (
				<div class="empty-state">
					<p class="empty-msg">No notes yet. Add them via <a href="/keystatic" class="ks-link">/keystatic</a>.</p>
				</div>
			) : (
				<div class="note-grid">
					{sorted.map((note) => (
						<article class="note-card">
							<div class="note-top">
								<p class="card-kicker">{note.data.status}</p>
								{note.data.pubDate && (
									<p class="note-date"><FormattedDate date={note.data.pubDate} /></p>
								)}
							</div>
							<h2 class="card-title">{note.data.title}</h2>
							<p class="card-copy">{note.data.result ?? note.data.description}</p>
							<div class="card-tag-row">
								{getTags(note.data.tags).map((tag) => <span class="card-tag">{tag}</span>)}
							</div>
							<a href={`/lab/${note.id}`} class="card-link">Read note ↗</a>
						</article>
					))}
				</div>
			)}
		</div>
	</section>
</SectionPage>

<style>
	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section {
		padding: 0 0 5rem;
	}

	.empty-state {
		padding: 1rem 0 0;
	}

	.empty-msg {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.76rem;
		color: var(--fg-tertiary);
	}

	.ks-link {
		text-decoration: none;
	}

	.note-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.note-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		transition: border-color 0.15s ease, background 0.15s ease;
	}

	.note-card:hover {
		border-color: var(--border-strong);
		background: var(--surface-hover);
	}

	.note-top {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: center;
	}

	.card-kicker,
	.card-tag,
	.card-link,
	.note-date {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.card-kicker,
	.note-date {
		margin: 0;
		color: var(--fg-tertiary);
	}

	.card-title {
		margin: 0;
		font-family: 'Syne', sans-serif;
		font-size: 1.4rem;
		letter-spacing: -0.03em;
	}

	.card-copy {
		margin: 0;
		color: var(--fg-secondary);
		line-height: 1.75;
	}

	.card-tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.card-tag {
		padding: 0.3rem 0.55rem;
		border-radius: 6px;
		border: 1px solid var(--accent-border);
		background: var(--accent-dim);
		color: var(--accent);
	}

	.card-link {
		text-decoration: none;
		color: var(--accent);
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.section {
			padding-bottom: 4rem;
		}

		.note-grid {
			grid-template-columns: 1fr;
		}

		.note-card {
			padding: 1.1rem;
		}
	}
</style>
