---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Nav from '../../components/Nav.astro';
import TerminalBar from '../../components/TerminalBar.astro';

export async function getStaticPaths() {
	const notes = await getCollection('lab');
	return notes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}

const { note } = Astro.props;
const { Content } = await render(note);
const tags = note.data.tags ? note.data.tags.split(',').map((tag) => tag.trim()) : [];
const summaryCards = [
	{ label: 'Problem', value: note.data.problem },
	{ label: 'Approach', value: note.data.approach },
	{ label: 'Result', value: note.data.result },
].filter((item) => item.value);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${note.data.title} — arthur3`} description={note.data.description} />
	</head>
	<body>
		<Nav />
		<TerminalBar />
		<main>
			<section class="note-hero">
				<div class="container">
					<a href="/lab" class="back-link">← All Notes</a>
					<div class="hero-card">
						<div class="hero-top">
							<div>
								<p class="eyebrow">{note.data.status}</p>
								<h1 class="note-title">{note.data.title}</h1>
							</div>
							{note.data.pubDate && (
								<p class="note-date"><FormattedDate date={note.data.pubDate} /></p>
							)}
						</div>
						<p class="note-description">{note.data.description}</p>
						{tags.length > 0 && (
							<div class="tag-row">
								{tags.map((tag) => <span class="tag">{tag}</span>)}
							</div>
						)}
						{summaryCards.length > 0 && (
							<div class="summary-grid">
								{summaryCards.map((item) => (
									<article class="summary-card">
										<p class="summary-label">{item.label}</p>
										<p class="summary-text">{item.value}</p>
									</article>
								))}
							</div>
						)}
					</div>
				</div>
			</section>

			<section class="note-content">
				<div class="container prose"><Content /></div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.note-hero {
		padding: 1.2rem 0 1.4rem;
	}

	.back-link,
	.eyebrow,
	.note-date,
	.tag,
	.summary-label {
		font-family: 'JetBrains Mono', monospace;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1rem;
		font-size: 0.72rem;
		text-decoration: none;
		color: var(--muted-faint);
	}

	.hero-card,
	.summary-card {
		border-radius: 28px;
		border: 1px solid var(--border);
		background:
			radial-gradient(circle at top right, rgba(var(--accent-rgb), 0.16), transparent 34%),
			linear-gradient(180deg, rgba(15, 34, 66, 0.98), rgba(8, 18, 34, 0.96));
		box-shadow: var(--box-shadow);
	}

	.hero-card {
		padding: 1.5rem;
	}

	.hero-top {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: start;
	}

	.eyebrow,
	.summary-label {
		margin: 0 0 0.8rem;
		font-size: 0.68rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted-faint);
	}

	.note-date {
		margin: 0;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted-faint);
	}

	.note-title {
		font-size: clamp(2.2rem, 5vw, 3.8rem);
		margin: 0;
	}

	.note-description,
	.summary-text {
		color: var(--muted-soft);
		line-height: 1.75;
	}

	.note-description {
		max-width: 44rem;
		font-size: 1rem;
		margin: 1rem 0 1.2rem;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.tag {
		padding: 0.35rem 0.55rem;
		border-radius: 999px;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		background: rgba(var(--accent-rgb), 0.08);
		color: var(--accent);
	}

	.summary-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
		margin-top: 1.3rem;
	}

	.summary-card {
		padding: 1rem;
		background: linear-gradient(180deg, rgba(13, 29, 55, 0.9), rgba(8, 18, 34, 0.95));
	}

	.summary-text {
		margin: 0;
	}

	.note-content {
		padding: 0 0 5.5rem;
	}

	.prose {
		max-width: 46rem;
		font-family: 'Inter', sans-serif;
		font-size: 0.98rem;
		line-height: 1.8;
		color: rgba(var(--fg-rgb), 0.82);
	}

	.prose :global(h2) {
		font-size: 1.5rem;
		margin: 2.4rem 0 1rem;
	}

	.prose :global(a) {
		text-decoration: none;
	}

	.prose :global(code) {
		font-family: 'JetBrains Mono', monospace;
	}

	@media (max-width: 900px) {
		.hero-top,
		.summary-grid {
			grid-template-columns: 1fr;
		}

		.hero-top {
			display: grid;
		}
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.note-hero {
			padding: 0.8rem 0 1.2rem;
		}

		.hero-card,
		.summary-card {
			border-radius: 22px;
		}

		.hero-card {
			padding: 1.15rem;
		}

		.summary-grid {
			grid-template-columns: 1fr;
		}

		.note-content {
			padding-bottom: 4.5rem;
		}
	}
</style>
