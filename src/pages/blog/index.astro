---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import SectionPage from '../../layouts/SectionPage.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<SectionPage title="Blog" description="Devlogs, technical opinions, and notes from building in public.">
	<Fragment slot="eyebrow">~/blog</Fragment>
	<Fragment slot="heading">Devlog.</Fragment>
	<Fragment slot="description">
		Honest write-ups on what I'm building, what broke, and what I learned. No polish, no marketing.
	</Fragment>

	<section class="section" id="main-content">
		<div class="container">
			{posts.length === 0 ? (
				<div class="empty-state">
					<p class="empty-msg">No posts yet. Check back soon — or add them via <a href="/keystatic" class="ks-link">/keystatic</a>.</p>
				</div>
			) : (
				<div class="post-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							<div class="post-top">
								<p class="card-kicker">devlog</p>
								{post.data.pubDate && (
									<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								)}
							</div>
							<h2 class="card-title">{post.data.title}</h2>
							{post.data.description && (
								<p class="card-copy">{post.data.description}</p>
							)}
							<span class="card-link">Read post ↗</span>
						</a>
					))}
				</div>
			)}
		</div>
	</section>
</SectionPage>

<style>
	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section {
		padding: 0 0 5rem;
	}

	.empty-state {
		padding: 1rem 0 0;
	}

	.empty-msg {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.76rem;
		color: var(--fg-tertiary);
	}

	.ks-link {
		text-decoration: none;
		color: var(--accent);
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.post-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-decoration: none;
		transition: border-color 0.15s ease, background 0.15s ease;
	}

	.post-card:hover {
		border-color: var(--border-strong);
		background: var(--surface-hover);
	}

	.post-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.card-kicker,
	.post-date,
	.card-link {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.card-kicker,
	.post-date {
		margin: 0;
		color: var(--fg-tertiary);
	}

	.card-title {
		margin: 0;
		font-family: 'Syne', sans-serif;
		font-size: 1.4rem;
		letter-spacing: -0.03em;
		color: var(--fg);
	}

	.card-copy {
		margin: 0;
		color: var(--fg-secondary);
		line-height: 1.75;
	}

	.card-link {
		color: var(--accent);
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.section {
			padding-bottom: 4rem;
		}

		.post-grid {
			grid-template-columns: 1fr;
		}

		.post-card {
			padding: 1.1rem;
		}
	}
</style>
