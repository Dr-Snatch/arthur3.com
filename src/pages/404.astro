---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404 — ${SITE_TITLE}`} description="Page not found." />
	</head>
	<body>
		<Nav />
		<main id="main-content">
			<section class="error-section">
				<div class="container">
					<p class="eyebrow">404</p>
					<h1 class="error-title">Nothing here.</h1>
					<p class="error-copy">
						The page you're looking for doesn't exist, was moved, or never did. Try browsing my projects or head back home.
					</p>
					<div class="error-actions">
						<a href="/" class="btn btn-primary">Back to Home</a>
						<a href="/projects" class="btn btn-secondary">Browse Projects</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.error-section {
		padding: 4rem 0 6rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
	}

	.error-title {
		font-size: clamp(3rem, 7vw, 5.5rem);
		margin: 0 0 1.25rem;
	}

	.error-copy {
		max-width: 38rem;
		font-size: 1rem;
		line-height: 1.75;
		color: var(--fg-secondary);
		margin: 0 0 2rem;
	}

	.error-copy code {
		font-family: 'JetBrains Mono', monospace;
		padding: 0.1em 0.35em;
		background: var(--surface-inset);
		border: 1px solid var(--border-faint);
		border-radius: 4px;
		font-size: 0.88em;
		color: var(--accent);
	}

	.error-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-bottom: 2.5rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.1rem;
		border-radius: 999px;
		border: none;
		text-decoration: none;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: opacity 0.15s ease, border-color 0.15s ease, color 0.15s ease;
	}

	.btn-primary {
		background: var(--accent);
		color: #0d0d0d;
	}

	.btn-primary:hover {
		color: #0d0d0d;
		opacity: 0.88;
	}

	.btn-secondary {
		background: transparent;
		color: var(--fg-secondary);
		border: 1px solid var(--border);
	}

	.btn-secondary:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	.terminal-hint {
		padding: 1.25rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		max-width: 28rem;
	}

	.hint-label {
		margin: 0 0 0.75rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
	}

	.hint-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.chip {
		display: inline-flex;
		padding: 0.3rem 0.55rem;
		border-radius: 6px;
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.65rem;
		letter-spacing: 0.08em;
		color: var(--accent);
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.error-section {
			padding: 2.5rem 0 4rem;
		}
	}
</style>
