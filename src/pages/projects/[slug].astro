---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Nav from '../../components/Nav.astro';
import TerminalBar from '../../components/TerminalBar.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const tags = project.data.tags ? project.data.tags.split(',').map((tag) => tag.trim()) : [];
const summaryCards = [
	{ label: 'Problem', value: project.data.problem },
	{ label: 'System', value: project.data.system },
	{ label: 'Result', value: project.data.result },
].filter((item) => item.value);
const isBeatMap = project.id === 'beatmap';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${project.data.title} — arthur3`} description={project.data.description} />
	</head>
	<body>
		<Nav />
		<TerminalBar />
		<main>
			<section class="project-hero">
				<div class="container">
					<a href="/projects" class="back-link">← All Projects</a>
					<div class="hero-card">
						<div class="hero-top">
							<div>
								<p class="eyebrow">{project.data.flagship ? 'Flagship Product' : project.data.status.replace('-', ' ')}</p>
								<h1 class="project-title">{project.data.title}</h1>
							</div>
							<div class="link-row">
								{project.data.repoUrl && (
									<a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="hero-link">GitHub ↗</a>
								)}
								{project.data.liveUrl && (
									<a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="hero-link">Live ↗</a>
								)}
							</div>
						</div>

						<p class="project-headline">{project.data.headline ?? project.data.description}</p>
						{tags.length > 0 && (
							<div class="tag-row">
								{tags.map((tag) => <span class="tag">{tag}</span>)}
							</div>
						)}
						{summaryCards.length > 0 && (
							<div class="summary-grid">
								{summaryCards.map((item) => (
									<article class="summary-card">
										<p class="summary-label">{item.label}</p>
										<p class="summary-text">{item.value}</p>
									</article>
								))}
							</div>
						)}
					</div>
				</div>
			</section>

			{isBeatMap && (
				<section class="showcase-section">
					<div class="container showcase-grid">
						<img
							src="/beatmap-shot-map.svg"
							alt="BeatMap placeholder showing the map and capture flow"
							class="showcase-shot"
						/>
						<img
							src="/beatmap-shot-journal.svg"
							alt="BeatMap placeholder showing the journal and insights flow"
							class="showcase-shot"
						/>
					</div>
				</section>
			)}

			<section class="project-content">
				<div class="container prose"><Content /></div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.project-hero {
		padding: 1.2rem 0 1.6rem;
	}

	.back-link,
	.eyebrow,
	.hero-link,
	.tag,
	.summary-label {
		font-family: 'JetBrains Mono', monospace;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1rem;
		font-size: 0.72rem;
		text-decoration: none;
		color: var(--accent);
	}

	.hero-card {
		padding: 1.5rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
	}

	.hero-top {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: start;
	}

	.eyebrow {
		margin: 0 0 0.8rem;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fg-faint);
	}

	.project-title {
		font-size: clamp(2.4rem, 5vw, 4rem);
		margin: 0;
	}

	.project-headline,
	.summary-text {
		color: var(--fg-muted);
		line-height: 1.75;
	}

	.project-headline {
		max-width: 44rem;
		font-size: 1rem;
		margin: 1rem 0 1.25rem;
	}

	.link-row,
	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	.hero-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: transparent;
		font-size: 0.72rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--fg-muted);
		transition: border-color 0.15s ease, color 0.15s ease;
	}

	.hero-link:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	.tag {
		padding: 0.3rem 0.55rem;
		border-radius: 6px;
		font-size: 0.65rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 1px solid var(--accent-border);
		background: var(--accent-dim);
		color: var(--accent);
	}

	.summary-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
		margin-top: 1.3rem;
	}

	.summary-card {
		padding: 1rem;
		border-radius: 8px;
		border: 1px solid var(--border);
		background: var(--bg-alt);
	}

	.summary-label {
		margin: 0 0 0.5rem;
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--fg-faint);
	}

	.summary-text {
		margin: 0;
	}

	.showcase-section {
		padding: 0 0 1.6rem;
	}

	.showcase-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.showcase-shot {
		width: 100%;
		border-radius: 12px;
		border: 1px solid var(--border);
	}

	.project-content {
		padding: 0 0 5rem;
	}

	.prose {
		max-width: 46rem;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		line-height: 1.7;
		color: var(--fg-muted);
	}

	.prose :global(h2) {
		font-size: 1.5rem;
		margin: 2.4rem 0 1rem;
		color: var(--fg);
	}

	.prose :global(a) {
		text-decoration: none;
	}

	.prose :global(code) {
		font-family: 'JetBrains Mono', monospace;
	}

	.prose :global(.architecture-diagram) {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.65rem;
		margin: 1.4rem 0 2rem;
	}

	.prose :global(.diagram-step) {
		padding: 0.7rem 0.85rem;
		border-radius: 8px;
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.76rem;
		color: var(--fg-muted);
	}

	.prose :global(.diagram-arrow) {
		color: var(--accent);
	}

	@media (max-width: 900px) {
		.summary-grid,
		.showcase-grid {
			grid-template-columns: 1fr;
		}

		.hero-top {
			flex-direction: column;
		}
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.project-hero {
			padding: 0.8rem 0 1.3rem;
		}

		.hero-card {
			padding: 1.15rem;
		}

		.project-content {
			padding-bottom: 4rem;
		}
	}
</style>
