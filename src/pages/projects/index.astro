---
import { getCollection } from 'astro:content';
import SectionPage from '../../layouts/SectionPage.astro';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => {
	const flagshipDelta = Number(b.data.flagship) - Number(a.data.flagship);
	if (flagshipDelta !== 0) return flagshipDelta;
	const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return db - da;
});

function getTags(tagString) {
	return tagString ? tagString.split(',').map((tag) => tag.trim()).slice(0, 3) : [];
}
---

<SectionPage title="Projects" description="Case studies for the systems, apps, and tools I build.">
	<Fragment slot="eyebrow">~/projects</Fragment>
	<Fragment slot="heading">Selected Systems.</Fragment>
	<Fragment slot="description">
		Projects framed around product value, technical difficulty, and the engineering decisions that make them hold together.
	</Fragment>

	<section class="section">
		<div class="container">
			{sorted.length === 0 ? (
				<div class="empty-state">
					<p class="empty-msg">No projects yet. Add them via <a href="/keystatic" class="ks-link">/keystatic</a>.</p>
				</div>
			) : (
				<div class="project-grid">
					{sorted.map((project) => (
						<a href={`/projects/${project.id}`} class={`project-card${project.data.flagship ? ' project-card-flagship' : ''}`}>
							<p class="card-kicker">{project.data.flagship ? 'Flagship product' : project.data.status.replace('-', ' ')}</p>
							<h2 class="card-title">{project.data.title}</h2>
							<p class="card-copy">{project.data.headline ?? project.data.description}</p>
							<div class="card-tag-row">
								{getTags(project.data.tags).map((tag) => <span class="card-tag">{tag}</span>)}
							</div>
							<span class="card-link">Read case study ↗</span>
						</a>
					))}
				</div>
			)}
		</div>
	</section>
</SectionPage>

<style>
	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section {
		padding: 0 0 5rem;
	}

	.empty-state {
		padding: 1rem 0 0;
	}

	.empty-msg {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.76rem;
		color: var(--fg-tertiary);
	}

	.ks-link {
		text-decoration: none;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-decoration: none;
		transition: border-color 0.15s ease, background 0.15s ease;
	}

	.project-card:hover {
		border-color: var(--border-strong);
		background: var(--surface-hover);
	}

	.project-card-flagship {
		border-color: var(--accent-border);
		background: var(--accent-dim);
	}

	.card-kicker,
	.card-tag,
	.card-link {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.card-kicker {
		margin: 0;
		color: var(--fg-tertiary);
	}

	.card-title {
		margin: 0;
		font-family: 'Syne', sans-serif;
		font-size: 1.5rem;
		letter-spacing: -0.03em;
		color: var(--fg);
	}

	.card-copy {
		margin: 0;
		color: var(--fg-secondary);
		line-height: 1.75;
	}

	.card-tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.card-tag {
		padding: 0.3rem 0.55rem;
		border-radius: 6px;
		border: 1px solid var(--accent-border);
		background: var(--accent-dim);
		color: var(--accent);
	}

	.card-link {
		color: var(--accent);
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.section {
			padding-bottom: 4rem;
		}

		.project-grid {
			grid-template-columns: 1fr;
		}

		.project-card {
			padding: 1.1rem;
		}
	}
</style>
