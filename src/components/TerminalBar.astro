---
import { getCollection } from 'astro:content';
import Terminal from './Terminal.jsx';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((post) => ({
		id: post.id,
		title: post.data.title,
		description: post.data.description,
		pubDate: post.data.pubDate.toISOString().slice(0, 10),
	}));
---

<div class="terminal-shell-offset" aria-hidden="true"></div>
<Terminal client:load transition:persist blogPosts={blogPosts} />

<!-- Expose Astro navigate for the Terminal's cd/open commands -->
<script>
	import { navigate } from 'astro:transitions/client';
	window.__astro_navigate = navigate;
</script>

<style is:global>
	.terminal-shell-offset {
		height: var(--nav-height);
	}

	body {
		padding-bottom: 5.5rem;
	}

	@media (max-width: 640px) {
		body {
			padding-bottom: 0;
		}
	}
</style>
