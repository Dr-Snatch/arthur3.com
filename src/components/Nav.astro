---
const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/projects', label: 'Projects' },
	{ href: '/lab', label: 'Notes' },
	{ href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
	if (href === '/') return currentPath === '/';
	return currentPath === href || currentPath.startsWith(href + '/');
}
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<nav class="navbar" aria-label="Main navigation">
	<div class="nav-container">
		<a href="/" class="brand" data-home-reset>
			<div class="brand-copy">
				<span class="brand-name"><span class="typewriter-text">arthur3</span><span class="cursor">█</span></span>
				<span class="brand-tag">AI Systems Developer</span>
			</div>
		</a>

		<div class="nav-actions desktop-only">
			<ul class="nav-links">
				{navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class={isActive(link.href) ? 'nav-active' : undefined}
							aria-current={isActive(link.href) ? 'page' : undefined}
							data-nav-link={link.label === 'Home' ? 'home' : undefined}
						>{link.label}</a>
					</li>
				))}
			</ul>
			<a href="/contact" class="work-cta">Let's Build</a>
		</div>

		<div class="mobile-controls mobile-only">
			<button type="button" class="mobile-menu-btn" aria-label="Toggle navigation menu" aria-expanded="false">
				<span class="hamburger" aria-hidden="true"></span>
			</button>
		</div>
	</div>

	<div class="mobile-dropdown" aria-hidden="true">
		<ul class="mobile-nav-links">
			{navLinks.map((link) => (
				<li>
					<a
						href={link.href}
						class={isActive(link.href) ? 'nav-active' : undefined}
						aria-current={isActive(link.href) ? 'page' : undefined}
						data-nav-link={link.label === 'Home' ? 'home' : undefined}
					>{link.label}</a>
				</li>
			))}
		</ul>
		<div class="mobile-utility-row">
			<a href="/contact" class="work-cta mobile-work-cta">Let's Build</a>
		</div>
	</div>
</nav>

<script is:inline data-astro-rerun>
	(function () {
		var mobileMenuBtn = document.querySelector('.mobile-menu-btn');
		var mobileDropdown = document.querySelector('.mobile-dropdown');
		if (mobileMenuBtn && mobileDropdown) {
			function setMenuState(isOpen) {
				mobileMenuBtn.classList.toggle('active', isOpen);
				mobileDropdown.classList.toggle('active', isOpen);
				mobileMenuBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
				mobileDropdown.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
			}

			mobileMenuBtn.addEventListener('click', function (event) {
				event.stopPropagation();
				setMenuState(!mobileDropdown.classList.contains('active'));
			});

			document.querySelectorAll('.mobile-nav-links a, .mobile-utility-row .work-cta').forEach(function (link) {
				link.addEventListener('click', function () { setMenuState(false); });
			});

			/* Document-level listener: add once, query fresh elements each time */
			if (!window.__navDocClick) {
				window.__navDocClick = true;
				document.addEventListener('click', function (event) {
					var dd = document.querySelector('.mobile-dropdown');
					var btn = document.querySelector('.mobile-menu-btn');
					if (dd && btn && !dd.contains(event.target) && !btn.contains(event.target)) {
						btn.classList.remove('active');
						dd.classList.remove('active');
						btn.setAttribute('aria-expanded', 'false');
						dd.setAttribute('aria-hidden', 'true');
					}
				});
			}
		}
	})();

	// Typewriter animation
	(function () {
		// Page-aware commands based on current path
		const currentPath = window.location.pathname.replace(/\/$/, '') || '/';

		const commandMap = {
			'/': ['arthur3', 'cd ~', 'ls ~', 'cat ~/README.md', 'pwd'],
			'/projects': ['cd ~/projects', 'ls ~/projects', 'tree ~/projects', 'pwd'],
			'/projects/beatmap': ['cd ~/projects/beatmap', 'cat ~/projects/beatmap/README.md', 'ls ~/projects/beatmap', 'pwd'],
			'/projects/rptext': ['cd ~/projects/rptext', 'cat ~/projects/rptext/README.md', 'ls ~/projects/rptext', 'pwd'],
			'/projects/arthur3-com': ['cd ~/projects/arthur3-com', 'cat ~/projects/arthur3-com/README.md', 'pwd'],
			'/lab': ['cd ~/lab', 'ls ~/lab/experiments', 'tree ~/lab', 'pwd'],
			'/blog': ['cd ~/blog', 'ls ~/blog', 'cat ~/blog/README.md', 'pwd'],
			'/contact': ['cd ~/contact', 'cat ~/contact/README.md', 'ls ~/contact', 'pwd']
		};

		// Default commands if path not found
		const commands = commandMap[currentPath] || ['arthur3', 'pwd', 'ls', 'help'];

		let currentIndex = 0;
		let currentText = '';
		let isDeleting = false;
		let charIndex = 0;

		const typewriterElement = document.querySelector('.typewriter-text');
		if (!typewriterElement) return;

		function type() {
			const currentCommand = commands[currentIndex];

			if (isDeleting) {
				currentText = currentCommand.substring(0, charIndex - 1);
				charIndex--;
			} else {
				currentText = currentCommand.substring(0, charIndex + 1);
				charIndex++;
			}

			typewriterElement.textContent = currentText;

			let typeSpeed = isDeleting ? 50 : 100;

			if (!isDeleting && charIndex === currentCommand.length) {
				typeSpeed = 2000; // Pause at end
				isDeleting = true;
			} else if (isDeleting && charIndex === 0) {
				isDeleting = false;
				currentIndex = (currentIndex + 1) % commands.length;
				typeSpeed = 500; // Pause before next command
			}

			setTimeout(type, typeSpeed);
		}

		// Start after a short delay
		setTimeout(type, 1000);
	})();
</script>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		padding: 0.75rem 0 0;
	}

	.nav-container {
		max-width: var(--page-max);
		height: calc(var(--nav-height) - 1.2rem);
		margin: 0 auto;
		padding: 0 1.2rem 0 1.35rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: var(--bg-raised);
		box-shadow: var(--shadow-md);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		text-decoration: none;
		color: inherit;
		min-width: 0;
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.brand-name {
		font-family: 'JetBrains Mono', monospace;
		font-size: 1.1rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--fg);
		min-width: 180px;
		display: inline-block;
	}

	.typewriter-text {
		display: inline-block;
	}

	.cursor {
		color: var(--accent);
		animation: blink 1.2s step-end infinite;
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		50.01%, 100% { opacity: 0; }
	}

	.brand-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-links a,
	.work-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 500;
		transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease, opacity 0.15s ease;
	}

	.nav-links a {
		padding: 0.75rem 1rem;
		min-height: 44px;
		color: var(--fg-secondary);
	}

	.nav-links a:hover {
		color: var(--fg);
	}

	.nav-links a.nav-active {
		color: var(--accent);
		position: relative;
	}

	.nav-links a.nav-active::after {
		content: '';
		position: absolute;
		bottom: 0.35rem;
		left: 50%;
		transform: translateX(-50%);
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--accent);
	}

	/* Focus states for nav links */
	.nav-links a:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		color: var(--fg);
	}

	.work-cta {
		padding: 1rem 2rem;
		min-height: 44px;
		min-width: 120px;
		background: var(--accent);
		color: #0d0d0d;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		border: none;
	}

	.work-cta:hover {
		color: #0d0d0d;
		opacity: 0.88;
	}

	/* Focus states for CTA button */
	.work-cta:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		box-shadow: 0 0 0 4px rgba(61, 214, 140, 0.2);
	}

	.mobile-controls,
	.mobile-dropdown {
		display: none;
	}

	.mobile-menu-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		min-width: 44px;
		min-height: 44px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: transparent;
		cursor: pointer;
		padding: 0;
		-webkit-tap-highlight-color: transparent;
	}

	.hamburger,
	.hamburger::before,
	.hamburger::after {
		width: 1.2rem;
		height: 2px;
		border-radius: 999px;
		background: var(--fg-secondary);
		transition: transform 0.25s ease, opacity 0.25s ease;
	}

	.hamburger {
		position: relative;
	}

	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		left: 0;
	}

	.hamburger::before { top: -0.4rem; }
	.hamburger::after { top: 0.4rem; }

	.mobile-menu-btn.active .hamburger { background: transparent; }
	.mobile-menu-btn.active .hamburger::before { transform: translateY(0.4rem) rotate(45deg); }
	.mobile-menu-btn.active .hamburger::after { transform: translateY(-0.4rem) rotate(-45deg); }

	/* Focus state for mobile menu button */
	.mobile-menu-btn:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		border-color: var(--accent);
	}

	.mobile-dropdown {
		position: fixed;
		top: calc(var(--nav-height) + 0.2rem);
		left: 1rem;
		right: 1rem;
		padding: 1rem;
		border: 1px solid var(--border-strong);
		border-radius: 12px;
		background: var(--bg-raised);
		box-shadow: var(--shadow-md);
		opacity: 0;
		visibility: hidden;
		transform: translateY(-0.6rem);
		transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
	}

	.mobile-dropdown.active {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.mobile-nav-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.35rem;
	}

	.mobile-nav-links a {
		display: block;
		padding: 1rem 1rem;
		min-height: 44px;
		border-radius: 8px;
		text-decoration: none;
		color: var(--fg-secondary);
	}

	.mobile-nav-links a.nav-active {
		color: var(--accent);
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
	}

	/* Focus state for mobile nav links */
	.mobile-nav-links a:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		background: rgba(61, 214, 140, 0.08);
		color: var(--fg);
	}

	.mobile-utility-row {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		margin-top: 1rem;
	}

	.mobile-work-cta {
		width: 100%;
		padding: 1rem;
		min-height: 44px;
	}

	/* Focus state for brand logo link */
	.brand:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		border-radius: 12px;
	}

	.mobile-only { display: none; }
	.desktop-only { display: flex; }

	@media (max-width: 768px) {
		.nav-container {
			margin: 0 1rem;
			padding: 0 0.9rem 0 1rem;
		}

		.brand-name {
			font-size: 0.9rem;
			min-width: 140px;
		}
		.brand-tag { font-size: 0.6rem; }
		.desktop-only { display: none; }
		.mobile-only { display: flex; }
		.mobile-dropdown { display: block; }
	}

	@media (max-width: 460px) {
		.brand-copy { max-width: 10rem; }

		.brand-tag {
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}
	}
</style>
