---
const primaryLinks = [
	{ href: '/projects', label: 'Projects' },
	{ href: '/blog', label: 'Blog' },
];

const dropdownLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/lab', label: 'Lab' },
	{ href: '/garden', label: 'Garden' },
];

const allLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/projects', label: 'Projects' },
	{ href: '/lab', label: 'Lab' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/garden', label: 'Garden' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
	if (href === '/') return currentPath === '/';
	return currentPath === href || currentPath.startsWith(href + '/');
}
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<nav class="navbar" aria-label="Main navigation">
	<div class="nav-container">
		<a href="/" class="brand" data-home-reset>
			<div class="brand-copy">
				<span class="brand-name"><span class="typewriter-text">arthur3</span><span class="cursor">█</span></span>
				<span class="brand-tag">AI Systems Developer</span>
			</div>
		</a>

		<div class="nav-right">
			<ul class="primary-links">
				{primaryLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class={isActive(link.href) ? 'nav-active' : undefined}
							aria-current={isActive(link.href) ? 'page' : undefined}
						>{link.label}</a>
					</li>
				))}
			</ul>
			<a href="/contact" class="work-cta desktop-only">Contact</a>
			<button type="button" class="menu-btn" aria-label="Toggle navigation menu" aria-expanded="false">
				<span class="hamburger" aria-hidden="true"></span>
			</button>
		</div>
	</div>

	<div class="menu-dropdown" aria-hidden="true">
		<ul class="menu-links desktop-only">
			{dropdownLinks.map((link) => (
				<li>
					<a
						href={link.href}
						class={isActive(link.href) ? 'nav-active' : undefined}
						aria-current={isActive(link.href) ? 'page' : undefined}
					>{link.label}</a>
				</li>
			))}
		</ul>
		<ul class="menu-links mobile-only">
			{allLinks.map((link) => (
				<li>
					<a
						href={link.href}
						class={isActive(link.href) ? 'nav-active' : undefined}
						aria-current={isActive(link.href) ? 'page' : undefined}
					>{link.label}</a>
				</li>
			))}
		</ul>
		<div class="menu-contact mobile-only">
			<a href="/contact" class="work-cta work-cta-full">Contact</a>
		</div>
	</div>
</nav>

<script is:inline data-astro-rerun>
	(function () {
		var menuBtn = document.querySelector('.menu-btn');
		var menuDropdown = document.querySelector('.menu-dropdown');
		if (menuBtn && menuDropdown) {
			function setMenuState(isOpen) {
				menuBtn.classList.toggle('active', isOpen);
				menuDropdown.classList.toggle('active', isOpen);
				menuBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
				menuDropdown.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
			}

			menuBtn.addEventListener('click', function (event) {
				event.stopPropagation();
				setMenuState(!menuDropdown.classList.contains('active'));
			});

			document.querySelectorAll('.menu-links a').forEach(function (link) {
				link.addEventListener('click', function () { setMenuState(false); });
			});

			if (!window.__navEscListener) {
				window.__navEscListener = true;
				document.addEventListener('keydown', function (event) {
					if (event.key === 'Escape') {
						var dd = document.querySelector('.menu-dropdown');
						var btn = document.querySelector('.menu-btn');
						if (dd && btn && dd.classList.contains('active')) {
							btn.classList.remove('active');
							dd.classList.remove('active');
							btn.setAttribute('aria-expanded', 'false');
							dd.setAttribute('aria-hidden', 'true');
							btn.focus();
						}
					}
				});
			}

			if (!window.__navDocClick) {
				window.__navDocClick = true;
				document.addEventListener('click', function (event) {
					var dd = document.querySelector('.menu-dropdown');
					var btn = document.querySelector('.menu-btn');
					if (dd && btn && !dd.contains(event.target) && !btn.contains(event.target)) {
						btn.classList.remove('active');
						dd.classList.remove('active');
						btn.setAttribute('aria-expanded', 'false');
						dd.setAttribute('aria-hidden', 'true');
					}
				});
			}
		}
	})();

	// Typewriter animation
	(function () {
		// Clean up any previous typewriter timer
		if (window.__typewriterTimer) {
			clearTimeout(window.__typewriterTimer);
			window.__typewriterTimer = null;
		}

		// Page-aware commands - show commands to navigate TO this page
		const currentPath = window.location.pathname.replace(/\/$/, '') || '/';

		const commandMap = {
			'/': ['arthur3', 'cd ~', 'cd /home/arthur', 'home'],
			'/projects': ['cd ~/projects', 'cd projects', 'cd /home/arthur/projects', 'open projects'],
			'/projects/beatmap': ['cd ~/projects/beatmap', 'cd /home/arthur/projects/beatmap', 'open beatmap', 'open ~/projects/beatmap'],
			'/projects/rptext': ['cd ~/projects/rptext', 'cd /home/arthur/projects/rptext', 'open rptext', 'open ~/projects/rptext'],
			'/projects/arthur3-com': ['cd ~/projects/arthur3-com', 'cd /home/arthur/projects/arthur3-com', 'open arthur3-com', 'open ~/projects/arthur3-com'],
			'/projects/housely': ['cd ~/projects/housely', 'cd /home/arthur/projects/housely', 'open housely', 'open ~/projects/housely'],
			'/lab': ['cd ~/lab', 'cd lab', 'cd /home/arthur/lab', 'open lab'],
			'/blog': ['cd ~/blog', 'cd blog', 'cd /home/arthur/blog', 'open blog'],
			'/garden': ['cd ~/garden', 'cd garden', 'cd /home/arthur/garden', 'open garden'],
			'/contact': ['cd ~/contact', 'cd contact', 'cd /home/arthur/contact', 'open contact']
		};

		const commands = commandMap[currentPath] || ['arthur3', 'cd ~'];

		let currentIndex = 0;
		let currentText = '';
		let isDeleting = false;
		let charIndex = 0;

		const typewriterElement = document.querySelector('.typewriter-text');
		if (!typewriterElement) return;

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			typewriterElement.textContent = commands[0];
			return;
		}

		function type() {
			const currentCommand = commands[currentIndex];

			if (isDeleting) {
				currentText = currentCommand.substring(0, charIndex - 1);
				charIndex--;
			} else {
				currentText = currentCommand.substring(0, charIndex + 1);
				charIndex++;
			}

			typewriterElement.textContent = currentText;

			let typeSpeed = isDeleting ? 50 : 100;

			if (!isDeleting && charIndex === currentCommand.length) {
				typeSpeed = 2000;
				isDeleting = true;
			} else if (isDeleting && charIndex === 0) {
				isDeleting = false;
				currentIndex = (currentIndex + 1) % commands.length;
				typeSpeed = 500;
			}

			window.__typewriterTimer = setTimeout(type, typeSpeed);
		}

		window.__typewriterTimer = setTimeout(type, 1000);

		// Cancel on view transition navigation
		if (!window.__typewriterSwapListener) {
			window.__typewriterSwapListener = true;
			document.addEventListener('astro:before-swap', function () {
				if (window.__typewriterTimer) {
					clearTimeout(window.__typewriterTimer);
					window.__typewriterTimer = null;
				}
			});
		}
	})();
</script>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		padding: 0.75rem 0 0;
	}

	.nav-container {
		max-width: var(--page-max);
		height: calc(var(--nav-height) - 1.2rem);
		margin: 0 auto;
		padding: 0 1.2rem 0 1.35rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: var(--bg-raised);
		box-shadow: var(--shadow-md);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		text-decoration: none;
		color: inherit;
		min-width: 0;
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.brand-name {
		font-family: 'JetBrains Mono', monospace;
		font-size: 1.1rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--fg);
		min-width: 180px;
		display: inline-block;
	}

	.typewriter-text {
		display: inline-block;
	}

	.cursor {
		color: var(--accent);
		animation: blink 1.2s step-end infinite;
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		50.01%, 100% { opacity: 0; }
	}

	.brand-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	/* Primary inline links (desktop only) */
	.primary-links {
		display: flex;
		align-items: center;
		gap: 0.1rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.primary-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 0.9rem;
		min-height: 44px;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.82rem;
		font-weight: 500;
		color: var(--fg-secondary);
		transition: color 0.15s ease, background 0.15s ease;
	}

	.primary-links a:hover {
		color: var(--fg);
	}

	.primary-links a.nav-active {
		color: var(--accent);
		background: var(--accent-dim);
		font-weight: 600;
	}

	.primary-links a:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		color: var(--fg);
	}

	/* Contact CTA */
	.work-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.5rem;
		min-height: 44px;
		border-radius: 999px;
		background: var(--accent);
		color: #0d0d0d;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		text-decoration: none;
		border: none;
		transition: opacity 0.15s ease;
	}

	.work-cta:hover {
		color: #0d0d0d;
		opacity: 0.88;
	}

	.work-cta:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		box-shadow: 0 0 0 4px rgba(61, 214, 140, 0.2);
	}

	.work-cta-full {
		width: 100%;
		padding: 0.85rem;
		text-align: center;
	}

	/* Hamburger button */
	.menu-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		min-width: 44px;
		min-height: 44px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: transparent;
		cursor: pointer;
		padding: 0;
		-webkit-tap-highlight-color: transparent;
		transition: border-color 0.2s ease, background-color 0.2s ease;
	}

	.menu-btn:hover {
		background: var(--hover-overlay);
		border-color: var(--border-strong);
	}

	.menu-btn:active {
		background: var(--active-overlay);
	}

	.menu-btn:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		border-color: var(--accent);
	}

	.hamburger,
	.hamburger::before,
	.hamburger::after {
		width: 1.1rem;
		height: 2px;
		border-radius: 999px;
		background: var(--fg-secondary);
		transition: transform 0.25s ease, opacity 0.25s ease;
	}

	.hamburger {
		position: relative;
	}

	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		left: 0;
	}

	.hamburger::before { top: -0.35rem; }
	.hamburger::after { top: 0.35rem; }

	.menu-btn.active .hamburger { background: transparent; }
	.menu-btn.active .hamburger::before { transform: translateY(0.35rem) rotate(45deg); }
	.menu-btn.active .hamburger::after { transform: translateY(-0.35rem) rotate(-45deg); }

	/* Dropdown panel */
	.menu-dropdown {
		position: fixed;
		top: calc(var(--nav-height) + 0.2rem);
		right: 1rem;
		width: 200px;
		padding: 0.4rem;
		border: 1px solid var(--border-strong);
		border-radius: 12px;
		background: var(--bg-raised);
		box-shadow: var(--shadow-md);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		opacity: 0;
		visibility: hidden;
		transform: translateY(-0.5rem);
		transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
	}

	.menu-dropdown.active {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.menu-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.1rem;
	}

	.menu-links a {
		display: block;
		padding: 0.65rem 0.9rem;
		min-height: 40px;
		border-radius: 8px;
		text-decoration: none;
		font-size: 0.84rem;
		font-weight: 500;
		color: var(--fg-secondary);
		transition: color 0.15s ease, background 0.15s ease;
	}

	.menu-links a:hover {
		color: var(--fg);
		background: var(--hover-overlay);
	}

	.menu-links a.nav-active {
		color: var(--accent);
		background: var(--accent-dim);
	}

	.menu-links a:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		color: var(--fg);
	}

	.menu-contact {
		padding-top: 0.4rem;
		margin-top: 0.3rem;
		border-top: 1px solid var(--border);
	}

	.brand:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring);
		outline-offset: var(--focus-ring-offset);
		border-radius: 12px;
	}

	.desktop-only { display: initial; }
	ul.desktop-only { display: grid; }
	a.desktop-only { display: inline-flex; }
	.mobile-only { display: none; }

	@media (max-width: 768px) {
		.nav-container {
			margin: 0 1rem;
			padding: 0 0.9rem 0 1rem;
		}

		.brand-name {
			font-size: 0.9rem;
			min-width: 140px;
		}

		.brand-tag { font-size: 0.6rem; }

		.primary-links {
			display: none;
		}

		.desktop-only,
		ul.desktop-only,
		a.desktop-only { display: none; }
		.mobile-only { display: block; }

		.menu-dropdown {
			left: 1rem;
			width: auto;
		}
	}

	@media (max-width: 460px) {
		.brand-copy { max-width: 10rem; }

		.brand-tag {
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}
	}
</style>
