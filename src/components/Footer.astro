---
import { SOCIAL_LINKS } from '../consts';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-copy">
			<p class="footer-title">Arthur Wheildon</p>
			<p class="footer-text">AI systems, secure native apps, and product-minded technical work.</p>
		</div>
		<div class="footer-meta">
			<span class="copyright">© {year}</span>
			<div class="links">
				{SOCIAL_LINKS.map((link) => {
					const isEmail = link.href.startsWith('mailto:');
					return (
						<a
							href={link.href}
							target={isEmail ? undefined : '_blank'}
							rel={isEmail ? undefined : 'noopener noreferrer'}
						>
							{link.label}
						</a>
					);
				})}
			</div>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		border-top: 1px solid var(--border-sub);
		padding: 2.2rem 1.5rem 2.6rem;
		background:
			linear-gradient(180deg, rgba(255, 250, 241, 0.5), rgba(255, 250, 241, 0)),
			linear-gradient(180deg, rgba(245, 230, 204, 0.5), rgba(245, 230, 204, 0.8));
	}

	.footer-inner {
		max-width: var(--page-max);
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1.5rem;
		padding: 1.35rem 1.5rem;
		border: 1px solid var(--border);
		border-radius: 28px;
		background: var(--surface-card);
		box-shadow: var(--box-shadow);
	}

	.footer-title {
		margin: 0 0 0.4rem;
		font-family: 'Fraunces', serif;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: -0.035em;
	}

	.footer-text,
	.copyright,
	.links a {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		line-height: 1.7;
		color: var(--muted-faint);
	}

	.footer-text {
		margin: 0;
		max-width: 24rem;
	}

	.footer-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.7rem;
	}

	.links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 1rem;
	}

	.links a {
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.links a:hover {
		color: var(--accent-blue-dark);
	}

	@media (max-width: 768px) {
		.site-footer {
			padding: 1.8rem 1rem 2.2rem;
		}

		.footer-inner,
		.footer-meta {
			align-items: flex-start;
		}

		.footer-inner {
			flex-direction: column;
		}

		.links {
			justify-content: flex-start;
		}
	}
</style>
