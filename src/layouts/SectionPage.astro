---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import TerminalBar from '../components/TerminalBar.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} — arthur3`} description={description} />
	</head>
	<body>
		<Nav />
		<TerminalBar />
		<main>
			<section class="page-hero">
				<div class="container">
					<div class="hero-panel">
						<p class="eyebrow"><slot name="eyebrow" /></p>
						<h1 class="page-heading"><slot name="heading" /></h1>
						<p class="page-desc"><slot name="description" /></p>
					</div>
				</div>
			</section>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.page-hero {
		padding: 1.4rem 0 2.4rem;
	}

	.hero-panel {
		position: relative;
		padding: 1.6rem;
		border-radius: 28px;
		border: 1px solid var(--border);
		background: var(--surface-card-strong);
		box-shadow: var(--box-shadow);
		overflow: hidden;
	}

	.hero-panel::after {
		content: '';
		position: absolute;
		top: 1rem;
		right: 1rem;
		width: 7rem;
		height: 7rem;
		border-radius: 24px;
		border: 1px solid rgba(var(--accent-blue-rgb), 0.12);
		background:
			linear-gradient(135deg, rgba(var(--accent-blue-rgb), 0.1), transparent 70%);
		transform: rotate(14deg);
	}

	.hero-panel > * {
		position: relative;
		z-index: 1;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted-faint);
	}

	.page-heading {
		font-size: clamp(2.4rem, 5vw, 4.1rem);
		margin: 0 0 1rem;
	}

	.page-desc {
		margin: 0;
		max-width: 40rem;
		font-size: 1.02rem;
		line-height: 1.75;
		color: var(--muted-soft);
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.page-hero {
			padding: 0.8rem 0 1.8rem;
		}

		.hero-panel {
			padding: 1.1rem;
			border-radius: 22px;
		}
	}
</style>
