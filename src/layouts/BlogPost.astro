---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Nav from '../components/Nav.astro';
import TerminalBar from '../components/TerminalBar.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — arthur3`} description={description} />
	</head>
	<body>
		<Nav />
		<main>
			<section class="post-hero">
				<div class="container">
					<a href="/blog" class="back-link">← All Posts</a>
					<div class="hero-card">
						<p class="eyebrow">devlog</p>
						<h1 class="post-title">{title}</h1>
						<p class="post-date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated"> · updated <FormattedDate date={updatedDate} /></span>
							)}
						</p>
					</div>
				</div>
			</section>

			<section class="post-content">
				<div class="container prose"><slot /></div>
			</section>
		</main>
		<Footer />
		<TerminalBar />
	</body>
</html>

<style>
	body {
		padding-top: 0;
	}

	.container {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 0 2rem;
	}

	.post-hero {
		padding: 1.2rem 0 1.6rem;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		text-decoration: none;
		color: var(--accent);
	}

	.hero-card {
		padding: 1.5rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
	}

	.eyebrow {
		margin: 0 0 0.8rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
	}

	.post-title {
		font-size: clamp(2.2rem, 5vw, 3.8rem);
		margin: 0 0 1rem;
	}

	.post-date,
	.updated {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--fg-tertiary);
		margin: 0;
	}

	.post-content {
		padding: 0 0 5rem;
	}

	.prose {
		max-width: 46rem;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		line-height: 1.7;
		color: var(--fg-secondary);
	}

	.prose :global(h2) {
		font-size: 1.5rem;
		margin: 2.4rem 0 1rem;
		color: var(--fg);
	}

	.prose :global(a) {
		text-decoration: none;
	}

	.prose :global(code) {
		font-family: 'JetBrains Mono', monospace;
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.post-hero {
			padding: 0.8rem 0 1.3rem;
		}

		.hero-card {
			padding: 1.15rem;
		}

		.post-content {
			padding-bottom: 4rem;
		}
	}
</style>
